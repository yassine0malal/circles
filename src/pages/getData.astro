---
import Layout from '../layouts/Layout.astro';
import { getActiveCircles } from '../api/circles';
import '../styles/global.css';

// Fetch real circles from the backend (already formatted by our API layer!)
const realCircles = await getActiveCircles();
---

<Layout title="Find a Circle | Circles.love">
  <main class="min-h-screen bg-[#faf9f6] py-40 px-6">
    <div class="max-w-[1140px] mx-auto">
      
      {/* Header Section */}
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h1 class="font-serif text-4xl md:text-5xl text-[#1a1714] mb-4">
          Available Circles
        </h1>
        <p class="text-[#6b5f4f] text-lg">
          Find a safe, guided space to process, heal, and grow with others who understand.
        </p>
      </div>

      {/* Grid of Circles */}
      {realCircles.length === 0 ? (
        <div class="text-center py-20 bg-white rounded-2xl border border-[#e8e2d9]">
          <p class="text-[#6b5f4f]">No circles are currently available. Check back soon!</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {realCircles.map((circle) => (
            <div class="group bg-white rounded-[24px] p-8 border border-[#e8e2d9] shadow-sm hover:shadow-[0_12px_40px_rgba(44,42,38,0.08)] hover:-translate-y-1 transition-all duration-300 flex flex-col">
              
              {/* Card Top: Badges & Price */}
              <div class="flex justify-between items-start mb-6">
                <div class="flex flex-wrap gap-2">
                  {/* Now using circle.category instead of formatType(circle.circleType) */}
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold tracking-wider uppercase bg-[#f5f1eb] text-[#6b5f4f]">
                    {circle.category}
                  </span>
                  
                  {/* Now using circle.location instead of circle.stateEligibility */}
                  {circle.location && (
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold tracking-wider uppercase bg-[#eef2eb] text-[#5c6b4a]">
                      {circle.location}
                    </span>
                  )}
                </div>
                <div class="text-right">
                  {/* Now using circle.price instead of formatPrice(circle.pricingCents) */}
                  <span class="block font-serif text-xl text-[#1a1714]">
                    {circle.price}
                  </span>
                  <span class="text-[11px] text-[#8a7d6b] uppercase tracking-wider font-medium">Per Session</span>
                </div>
              </div>

              {/* Title & Description */}
              <div class="mb-6 flex-grow">
                <h2 class="font-serif text-2xl text-[#1a1714] leading-tight mb-3 group-hover:text-[#EE8F8B] transition-colors">
                  {circle.title}
                </h2>
                {/* Now using circle.bio instead of circle.description */}
                <p class="text-[#6b5f4f] text-sm leading-relaxed line-clamp-3">
                  {circle.bio}
                </p>
              </div>

              {/* Details List */}
              <ul class="space-y-3 mb-8 border-t border-[#f0ebe1] pt-6">
                
                {/* Schedule uses groupMeets now */}
                {circle.groupMeets && (
                  <li class="flex items-center gap-3 text-sm text-[#6b5f4f]">
                    <svg class="w-4 h-4 text-[#EE8F8B]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    {circle.groupMeets}
                  </li>
                )}
                
                {/* Capacity uses maxMembers now */}
                {circle.maxMembers && (
                  <li class="flex items-center gap-3 text-sm text-[#6b5f4f]">
                    <svg class="w-4 h-4 text-[#EE8F8B]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                    Max {circle.maxMembers} participants
                  </li>
                )}
              </ul>

              {/* Call to Action */}
              <a 
                href={`/circles/${circle.id}`} 
                class="block w-full py-3 px-4 bg-[#2d2822] text-[#f5f1eb] text-center text-sm font-semibold rounded-full hover:bg-[#EE8F8B] hover:text-white transition-colors duration-200"
              >
                View full details
              </a>
            </div>
          ))}
        </div>
      )}
    </div>
  </main>
</Layout>