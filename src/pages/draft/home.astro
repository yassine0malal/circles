          circle.love doesn't track your search or store anything about your
          health — we just helped you find each other.
        </p>
        <div class="reassure">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
            ><path
              d="M8 1.5 2.5 4v3.5C2.5 11 5 13.5 8 14.5c3-1 5.5-3.5 5.5-7V4L8 1.5Z"
              stroke="currentColor"
              stroke-width="1.3"
              stroke-linejoin="round"></path><path
              d="m5.8 8 1.6 1.6L10.4 6.5"
              stroke="currentColor"
              stroke-width="1.3"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
          <span
            >Nothing you searched is saved. No cookies, no trackers, no record
            of you.</span
          >
        </div>
        <div class="acts">
          <button
            class="inline-flex items-center gap-2 font-semibold text-[15px] px-6 py-3 rounded-full transition-all duration-200 hover:-translate-y-px group/btn bg-transparent text-ink border-line hover:border-ink hover:bg-raised"
            id="cancelBtn">Stay here</button
          >
          <a
            class="inline-flex items-center gap-2 font-semibold text-[15px] px-6 py-3 rounded-full transition-all duration-200 hover:-translate-y-px group/btn bg-ink text-cream hover:-translate-y-[1px] hover:shadow-[0_2px_4px_rgba(42,33,53,0.05),0_18px_44px_rgba(42,33,53,0.10)]"
            id="proceedBtn"
            href="#"
            rel="noreferrer noopener"
            target="_blank"
            >Continue securely <svg
              class="transition-transform duration-200 group-hover/btn:translate-x-[3px]"
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              ><path
                d="M3 8h9M8 4l4 4-4 4"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            ></a
          >
        </div>
      </div>
    </div>

    <script>
      // sticky nav background
      const nav = document.getElementById("nav");
      const onScroll = () => {
        nav.classList.toggle("solid", window.scrollY > 40);
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      // category chips (single-select demo)
      document.getElementById("chips").addEventListener("click", (e) => {
        const b = e.target.closest(".chip-f");
        if (!b) return;
        document
          .querySelectorAll("#chips .chip-f")
          .forEach((c) => c.classList.remove("on"));
        b.classList.add("on");
      });

      // interstitial handoff
      const overlay = document.getElementById("overlay");
      const mName = document.getElementById("mName");
      let lastFocus = null;
      const openModal = (first) => {
        mName.textContent = first || "them";
        lastFocus = document.activeElement;
        overlay.classList.add("open");
        document.getElementById("cancelBtn").focus();
      };
      const closeModal = () => {
        overlay.classList.remove("open");
        if (lastFocus) lastFocus.focus();
      };
      document.querySelectorAll(".cta").forEach((button) => {
        button.addEventListener("click", () => openModal(button.dataset.first));
      });
      document
        .getElementById("cancelBtn")
        .addEventListener("click", closeModal);
      document.getElementById("proceedBtn").addEventListener("click", (e) => {
        e.preventDefault();
        closeModal();
      });
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) closeModal();
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && overlay.classList.contains("open"))
          closeModal();
      });
    </script>
  </body>
</html>
