<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>circle.love — find your circle of belonging</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --r-card: 22px;
        --r-pill: 999px;
        --sh-soft:
          0 1px 2px rgba(42, 33, 53, 0.04), 0 10px 30px rgba(42, 33, 53, 0.06);
        --sh-lift:
          0 2px 4px rgba(42, 33, 53, 0.05), 0 18px 44px rgba(42, 33, 53, 0.1);
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--color-canvas);
        color: var(--color-ink);
        font-family: var(--font-body);
        font-size: 17px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        letter-spacing: -0.005em;
      }
      .wrap {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 28px;
      }
      a {
        color: inherit;
      }
      .eye {
        font-family: var(--font-body);
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--color-sage-deep);
      }

      /* ——— nav ——— */
      nav {
        position: sticky;
        top: 0;
        z-index: 40;
        background: rgba(36, 27, 46, 0);
        transition:
          background 0.3s ease,
          backdrop-filter 0.3s ease;
      }
      nav.solid {
        background: rgba(248, 242, 238, 0.85);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--color-line);
      }
      .nav-in {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 0;
      }
      .mark {
        display: flex;
        align-items: center;
        gap: 11px;
        text-decoration: none;
      }
      .mark .word {
        font-family: var(--font-display);
        font-size: 23px;
        font-weight: 500;
        letter-spacing: -0.02em;
        color: var(--color-cream);
        transition: color 0.3s ease;
      }
      .mark .word b {
        font-weight: 500;
        font-style: italic;
        color: var(--color-rose);
      }
      nav.solid .mark .word {
        color: var(--color-ink);
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .nav-links a.txt {
        font-size: 0.9rem;
        font-weight: 500;
        padding: 9px 14px;
        border-radius: var(--r-pill);
        text-decoration: none;
        color: var(--color-cream);
        opacity: 0.85;
        transition:
          opacity 0.2s,
          color 0.3s;
      }
      nav.solid .nav-links a.txt {
        color: var(--color-ink-soft);
      }
      .nav-links a.txt:hover {
        opacity: 1;
      }

      /* ——— hero ——— */
      .hero {
        position: relative;
        background: radial-gradient(
          120% 90% at 50% 0%,
          #322341 0%,
          #241b2e 58%,
          #1f1728 100%
        );
        color: var(--color-cream);
        overflow: hidden;
        margin-top: -74px;
        padding: 170px 0 110px;
      }
      .rings {
        position: absolute;
        inset: 0;
        pointer-events: none;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.9;
      }
      .rings svg {
        width: min(1100px, 150%);
        height: auto;
      }
      .glow {
        position: absolute;
        left: 50%;
        top: 46%;
        width: 520px;
        height: 520px;
        transform: translate(-50%, -50%);
        background: radial-gradient(
          circle,
          rgba(224, 163, 92, 0.22) 0%,
          rgba(193, 111, 114, 0.1) 38%,
          transparent 66%
        );
        filter: blur(6px);
        pointer-events: none;
      }
      .hero-in {
        position: relative;
        z-index: 2;
        text-align: center;
        max-width: 780px;
        margin: 0 auto;
      }
      .hero .eye {
        color: var(--color-amber);
        margin-bottom: 22px;
        display: inline-block;
      }
      .hero h1 {
        font-family: var(--font-display);
        font-weight: 300;
        font-size: clamp(2.7rem, 6.4vw, 5rem);
        line-height: 1.03;
        letter-spacing: -0.03em;
        margin: 0 0 22px;
      }
      .hero h1 em {
        font-style: italic;
        color: var(--color-rose);
      }
      .hero .sub {
        font-size: 1.18rem;
        color: rgba(246, 236, 227, 0.82);
        max-width: 54ch;
        margin: 0 auto 36px;
        line-height: 1.6;
      }
      .hero-cta {
        display: flex;
        gap: 14px;
        justify-content: center;
        flex-wrap: wrap;
      }
      .hero .fine {
        margin-top: 26px;
        font-size: 0.82rem;
        letter-spacing: 0.04em;
        color: rgba(246, 236, 227, 0.6);
      }
      .hero .fine b {
        color: rgba(246, 236, 227, 0.85);
        font-weight: 600;
      }
      @keyframes drift {
        0%,
        100% {
          transform: translateY(0) scale(1);
        }
        50% {
          transform: translateY(-14px) scale(1.012);
        }
      }
      .ring-float {
        animation: drift 13s ease-in-out infinite;
        transform-origin: center;
      }

      /* ——— sections ——— */
      section {
        position: relative;
      }
      .pad {
        padding: 96px 0;
      }
      .center {
        text-align: center;
        max-width: 640px;
        margin: 0 auto 56px;
      }
      .center h2 {
        font-family: var(--font-display);
        font-weight: 300;
        font-size: clamp(2rem, 4vw, 2.9rem);
        letter-spacing: -0.025em;
        line-height: 1.08;
        margin: 0.4em 0 0.35em;
      }
      .center h2 em {
        font-style: italic;
        color: var(--color-rose);
      }
      .center p {
        color: var(--color-ink-soft);
        font-size: 1.06rem;
        margin: 0;
      }

      /* ——— two kinds ——— */
      .kinds {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 22px;
      }
      .kind-card {
        position: relative;
        border-radius: var(--r-card);
        padding: 38px 34px 34px;
        overflow: hidden;
        border: 1px solid var(--color-line);
      }
      .kind-card.therapy {
        background: linear-gradient(160deg, #eff1ec 0%, #e7ece5 100%);
      }
      .kind-card.healing {
        background: linear-gradient(160deg, #fbf0e3 0%, #f7e9d8 100%);
      }
      .kind-card .glyph {
        width: 46px;
        height: 46px;
        margin-bottom: 20px;
      }
      .kind-card h3 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: 1.7rem;
        letter-spacing: -0.02em;
        margin: 0 0 10px;
      }
      .kind-card p {
        color: var(--color-ink-soft);
        font-size: 0.98rem;
        margin: 0 0 18px;
      }
      .kind-card .who {
        font-size: 0.84rem;
        font-weight: 600;
        color: var(--color-ink);
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .kind-card .who span {
        font-weight: 400;
        color: var(--color-ink-soft);
      }

      /* ——— discovery ——— */
      .discover {
        background: linear-gradient(
          180deg,
          var(--color-canvas) 0%,
          #f4ede7 100%
        );
      }
      .filters {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
      }
      .selectish {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--color-raised);
        border: 1px solid var(--color-line);
        border-radius: 12px;
        padding: 11px 16px;
        font-weight: 600;
        font-size: 0.92rem;
        cursor: pointer;
      }
      .selectish .lk {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--color-sage-deep);
        font-weight: 600;
      }
      .chips {
        display: flex;
        gap: 9px;
        flex-wrap: wrap;
        justify-content: center;
        margin-bottom: 44px;
      }
      .chip-f {
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 500;
        padding: 8px 16px;
        border-radius: var(--r-pill);
        border: 1px solid var(--color-line);
        background: var(--color-raised);
        color: var(--color-ink-soft);
        cursor: pointer;
        transition: all 0.16s ease;
      }
      .chip-f:hover {
        border-color: var(--color-sage);
        color: var(--color-ink);
      }
      .chip-f.on {
        background: var(--color-ink);
        color: var(--color-cream);
        border-color: var(--color-ink);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }
      .card {
        display: flex;
        flex-direction: column;
        background: var(--color-raised);
        border: 1px solid var(--color-line);
        border-radius: var(--r-card);
        padding: 24px;
        box-shadow: var(--sh-soft);
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease;
      }
      .card:hover {
        transform: translateY(-4px);
        box-shadow: var(--sh-lift);
      }
      .kind {
        align-self: flex-start;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 5px 11px;
        border-radius: var(--r-pill);
      }
      .kind-therapy {
        background: rgba(110, 139, 122, 0.15);
        color: var(--color-sage-deep);
      }
      .kind-healing {
        background: rgba(224, 163, 92, 0.2);
        color: #9a6a22;
      }
      .card h3 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: 1.45rem;
        letter-spacing: -0.02em;
        margin: 15px 0 4px;
      }
      .card .by {
        font-size: 0.86rem;
        color: var(--color-ink-soft);
        margin-bottom: 18px;
      }
      .meta-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
        font-size: 0.88rem;
        margin-bottom: 4px;
      }
      .meta-list div {
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--color-ink-soft);
      }
      .meta-list b {
        color: var(--color-ink);
        font-weight: 600;
      }
      .ic {
        width: 15px;
        height: 15px;
        flex: none;
        color: var(--color-sage);
      }
      .card .meta-list {
        margin-bottom: auto;
      }
      .card .foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 18px;
        margin-top: 20px;
        border-top: 1px solid var(--color-line);
      }
      .price b {
        font-family: var(--font-display);
        font-size: 1.3rem;
        font-weight: 400;
      }
      .price span {
        font-size: 0.78rem;
        color: var(--color-ink-soft);
      }
      .mini-ring {
        display: flex;
        align-items: center;
        gap: 9px;
      }
      .mini-ring .r {
        position: relative;
        width: 42px;
        height: 42px;
      }
      .mini-ring .r svg {
        transform: rotate(-90deg);
      }
      .mini-ring .r b {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-display);
        font-size: 0.95rem;
      }
      .mini-ring .txt {
        font-size: 0.7rem;
        line-height: 1.2;
        color: var(--color-ink-soft);
      }
      .mini-ring .txt b {
        display: block;
        color: var(--color-ink);
        font-family: var(--font-body);
        font-size: 0.78rem;
        font-weight: 600;
      }
      .card .cta {
        margin-top: 18px;
        width: 100%;
        justify-content: center;
      }
      .more {
        text-align: center;
        margin-top: 46px;
      }

      /* ——— how ——— */
      .how {
        background: var(--color-canvas);
      }
      .steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        counter-reset: s;
      }
      .step {
        position: relative;
        padding-top: 14px;
      }
      .step .n {
        font-family: var(--font-display);
        font-style: italic;
        font-weight: 400;
        font-size: 2.3rem;
        color: var(--color-rose);
        line-height: 1;
        margin-bottom: 14px;
      }
      .step h3 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: 1.35rem;
        letter-spacing: -0.02em;
        margin: 0 0 8px;
      }
      .step p {
        color: var(--color-ink-soft);
        font-size: 0.95rem;
        margin: 0;
      }
      .step:not(:last-child)::after {
        content: "";
        position: absolute;
        top: 24px;
        right: -15px;
        width: 30px;
        height: 1px;
        background: var(--color-line);
      }

      /* ——— facilitator ——— */
      .facil {
        background: linear-gradient(165deg, #322341 0%, #241b2e 100%);
        color: var(--color-cream);
        border-radius: 30px;
        padding: 64px 56px;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 50px;
        align-items: center;
      }
      .facil .eye {
        color: var(--color-amber);
      }
      .facil h2 {
        font-family: var(--font-display);
        font-weight: 300;
        font-size: clamp(1.9rem, 3.4vw, 2.6rem);
        letter-spacing: -0.025em;
        line-height: 1.1;
        margin: 0.4em 0 0.5em;
      }
      .facil h2 em {
        font-style: italic;
        color: var(--color-rose);
      }
      .facil p {
        color: rgba(246, 236, 227, 0.8);
        margin: 0 0 26px;
        max-width: 42ch;
      }
      .facil ul {
        list-style: none;
        padding: 0;
        margin: 0 0 30px;
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .facil li {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        font-size: 0.96rem;
        color: rgba(246, 236, 227, 0.92);
      }
      .facil li svg {
        flex: none;
        margin-top: 3px;
        color: var(--color-amber);
      }
      .facil-card {
        background: rgba(246, 236, 227, 0.06);
        border: 1px solid rgba(246, 236, 227, 0.14);
        border-radius: 20px;
        padding: 26px;
      }
      .facil-card .lbl {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(246, 236, 227, 0.55);
        font-weight: 600;
        margin-bottom: 14px;
      }
      .facil-card .price-big {
        font-family: var(--font-display);
        font-weight: 300;
        font-size: 3rem;
        line-height: 1;
      }
      .facil-card .price-big span {
        font-size: 1rem;
        color: rgba(246, 236, 227, 0.6);
      }
      .facil-card .cut {
        margin: 18px 0 22px;
        padding: 14px 16px;
        background: rgba(110, 139, 122, 0.18);
        border-radius: 12px;
        font-size: 0.86rem;
        color: #cfe0d4;
      }
      .facil-card .cut b {
        color: #fff;
      }

      /* ——— trust ——— */
      .trust {
        text-align: center;
      }
      .trust .promises {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-top: 48px;
        text-align: left;
      }
      .promise {
        padding: 26px;
        border: 1px solid var(--color-line);
        border-radius: var(--r-card);
        background: var(--color-raised);
      }
      .promise .pic {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
        background: rgba(110, 139, 122, 0.14);
        color: var(--color-sage-deep);
      }
      .promise b {
        display: block;
        font-family: var(--font-display);
        font-weight: 400;
        font-size: 1.2rem;
        margin-bottom: 6px;
      }
      .promise span {
        font-size: 0.92rem;
        color: var(--color-ink-soft);
      }

      /* ——— footer ——— */
      footer {
        background: var(--color-ink-2);
        color: rgba(246, 236, 227, 0.72);
        padding: 64px 0 40px;
      }
      .foot-grid {
        display: flex;
        justify-content: space-between;
        gap: 40px;
        flex-wrap: wrap;
        padding-bottom: 36px;
        border-bottom: 1px solid rgba(246, 236, 227, 0.12);
      }
      footer .mark .word {
        color: var(--color-cream);
      }
      .foot-tag {
        max-width: 34ch;
        font-size: 0.9rem;
        margin-top: 16px;
        line-height: 1.6;
      }
      .foot-cols {
        display: flex;
        gap: 60px;
        flex-wrap: wrap;
      }
      .foot-col h4 {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(246, 236, 227, 0.5);
        margin: 0 0 14px;
        font-weight: 600;
      }
      .foot-col a {
        display: block;
        font-size: 0.92rem;
        color: rgba(246, 236, 227, 0.8);
        text-decoration: none;
        margin-bottom: 10px;
      }
      .foot-col a:hover {
        color: var(--color-cream);
      }
      .foot-base {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        padding-top: 28px;
        font-size: 0.82rem;
        color: rgba(246, 236, 227, 0.5);
      }

      /* ——— modal ——— */
      .overlay {
        position: fixed;
        inset: 0;
        z-index: 90;
        background: rgba(31, 23, 40, 0.55);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
        opacity: 0;
        transition: opacity 0.25s ease;
      }
      .overlay.open {
        display: flex;
        opacity: 1;
      }
      .modal {
        background: var(--color-raised);
        border-radius: 26px;
        padding: 38px 36px;
        max-width: 440px;
        width: 100%;
        box-shadow: 0 30px 80px rgba(31, 23, 40, 0.4);
        transform: translateY(14px) scale(0.98);
        transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      .overlay.open .modal {
        transform: translateY(0) scale(1);
      }
      .modal .glyph {
        width: 56px;
        height: 56px;
        margin-bottom: 20px;
      }
      .modal h3 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: 1.55rem;
        letter-spacing: -0.02em;
        margin: 0 0 12px;
      }
      .modal h3 em {
        font-style: italic;
        color: var(--color-rose);
      }
      .modal p {
        font-size: 0.95rem;
        color: var(--color-ink-soft);
        margin: 0;
      }
      .modal .reassure {
        display: flex;
        gap: 11px;
        align-items: flex-start;
        background: rgba(110, 139, 122, 0.1);
        border-radius: 14px;
        padding: 14px 16px;
        font-size: 0.85rem;
        color: var(--color-sage-deep);
        margin: 20px 0 24px;
      }
      .modal .reassure svg {
        flex: none;
        margin-top: 1px;
      }
      .modal .acts {
        display: flex;
        gap: 12px;
      }
      .modal
        .acts
        .inline-flex
        items-center
        gap-2
        font-semibold
        text-[15px]
        px-6
        py-3
        rounded-full
        transition-all
        duration-200
        hover:-translate-y-px
        group/btn {
        flex: 1;
        justify-content: center;
      }

      @media (max-width: 880px) {
        .kinds,
        .grid,
        .steps,
        .trust .promises,
        .facil {
          grid-template-columns: 1fr;
        }
        .facil {
          padding: 44px 30px;
          gap: 34px;
        }
        .step:not(:last-child)::after {
          display: none;
        }
      }
      @media (max-width: 560px) {
        .pad {
          padding: 68px 0;
        }
        .nav-links a.txt {
          display: none;
        }
        .hero {
          padding: 140px 0 84px;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        * {
          animation: none !important;
          transition: none !important;
        }
      }
    </style>
  </head>
  <body>
    <nav id="nav">
      <div class="wrap nav-in">
        <a class="mark" href="#"
          ><svg
            width="30"
            height="30"
            viewBox="0 0 34 34"
            fill="none"
            aria-hidden="true"
            ><circle cx="13" cy="17" r="9" stroke="#C16F72" stroke-width="2"
            ></circle><circle
              cx="21"
              cy="17"
              r="9"
              stroke="#6E8B7A"
              stroke-width="2"></circle></svg
          ><span class="word">circle<b>.love</b></span></a
        >
        <div class="nav-links">
          <a class="txt" href="#discover">Find a circle</a>
          <a class="txt" href="#facilitators">For facilitators</a>
          <a
