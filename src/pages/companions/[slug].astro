---
import Layout from '../../layouts/Layout.astro';
import CircleCard from '../../components/CircleCard.astro';

// Circles data
const therapistCircles = [
  {
    title: 'Good Grief',
    category: 'Grief & Loss',
    facilitator: 'Art Kosmopoulos',
    date: 'Dec 12',
    time: '8:00 PM EST',
    spots: '4/8',
    location: 'Virtual',
    image: 'https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=600&h=400&fit=crop',
    price: 'Pricing'
  },
  {
    title: 'Anxiety & Calm',
    category: 'Anxiety & Stress',
    facilitator: 'Art Kosmopoulos',
    date: 'Dec 14',
    time: '7:00 PM EST',
    spots: '3/8',
    location: 'Virtual',
    image: 'https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=600&h=400&fit=crop',
    price: 'Pricing'
  },
  {
    title: 'Life Transitions',
    category: 'Life Transition',
    facilitator: 'Art Kosmopoulos',
    date: 'Dec 16',
    time: '6:00 PM EST',
    spots: '5/8',
    location: 'Virtual',
    image: 'https://images.unsplash.com/photo-1516307073036-4d4205e2f6d2?w=600&h=400&fit=crop',
    price: 'Pricing'
  }
];

export async function getStaticPaths() {
  const therapists = [
    {
      slug: 'art-kosmopoulos',
      name: 'Art Kosmopoulos',
      credentials: 'Psychologist, PhD',
      pronouns: 'he, him',
      verified: true,
      endorsed: 3,
      location: 'Brooklyn, NY 11242',
      phone: '(516) 774-3154',
      image: 'https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400&h=400&fit=crop&crop=face',
      practiceName: 'The Healing Space',
      address: '2401 S Monroe, Brooklyn, NY 11242',
      specialties: ['Trauma and PTSD', 'Anxiety', 'Depression'],
      cost: '$200',
      acceptsInsurance: true,
      insurance: ['Aetna', 'Cigna', 'UnitedHealthcare'],
      sessionType: 'Individual one-on-one therapy',
      bio: [
        'My name is Art Kosmopoulos, and I am a licensed Psychologist. My therapeutic approach is multifaceted, integrating holistic & body-centered methodologies with evidence-based practice, all underpinned by a trauma-informed framework.',
        'In my clinical practice, I have gained substantial experience addressing a broad spectrum of issues, including but not limited to anxiety, depression, trauma, interpersonal and transitional challenges. It is my objective to provide a supportive and transformative therapeutic experience, tailored to the unique needs of each individual client.',
        'I assist clients in cultivating a deeper understanding of the interconnectedness of mind, body & spirit, recognizing that healing & growth occur when all these aspects are addressed in unison. Through an integrative approach, I provide a comprehensive therapeutic experience that addresses immediate concerns & fosters long-term resilience & well-being.'
      ],
      // NEW: Certificates section
      certificates: [
        {
          title: 'Licensed Psychologist',
          issuer: 'New York State Education Department',
          license: 'NY-PSY-018432',
          year: '2015',
          status: 'Active',
          url: '#'
        },
        {
          title: 'Certified Clinical Trauma Professional',
          issuer: 'International Association of Trauma Professionals',
          license: 'CCTP-II-7721',
          year: '2019',
          status: 'Active',
          url: '#'
        },
        {
          title: 'EMDR Trained Practitioner',
          issuer: 'EMDR International Association',
          license: 'EMDR-44219',
          year: '2020',
          status: 'Active',
          url: '#'
        }
      ]
    },
    {
      slug: 'alex-shiflett',
      name: 'Alex Shiflett',
      credentials: 'Counselor, LMHC',
      pronouns: 'they, them',
      verified: true,
      endorsed: 3,
      location: 'Brooklyn, NY 11242',
      phone: '(929) 531-5957',
      image: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&h=400&fit=crop&crop=face',
      practiceName: 'Inclusive Therapy Center',
      address: '189 Broadway, Brooklyn, NY 11242',
      specialties: ['LGBTQ+ Issues', 'Anxiety', 'Relationship Issues'],
      cost: '$180',
      acceptsInsurance: true,
      insurance: ['Blue Cross', 'Oscar'],
      sessionType: 'Individual one-on-one therapy',
      bio: [
        'Hello! My name is Alex. I am a helper and trained counselor welcoming clients who have specifically been ostracized or misunderstood by the mental health industrial complex.',
        'Currently, I am offering sessions geared towards helping clients explicitly gate-kept from traditional therapeutic spaces. My approach is warm, non-judgmental, and centered on your lived experience.'
      ],
      // NEW: Certificates section
      certificates: [
        {
          title: 'Licensed Mental Health Counselor',
          issuer: 'New York State Office of Professions',
          license: 'NY-LMHC-009821',
          year: '2018',
          status: 'Active',
          url: '#'
        },
        {
          title: 'Certified LGBTQ+ Affirming Therapist',
          issuer: 'Modern Sex Therapy Institutes',
          license: 'LGBTQ-AT-3312',
          year: '2021',
          status: 'Active',
          url: '#'
        }
      ]
    }
  ];

  return therapists.map(t => ({
    params: { slug: t.slug },
    props: { therapist: t }
  }));
}

const { therapist } = Astro.props;
---

<Layout title={`${therapist.name} — Circle Share`}>
  <div class="h-23 bg-ink/20 backdrop-blur-md border-b border-line transition-[background,backdrop-filter] duration-300 ease-in-out">
  <!-- Your content here -->
</div>
  <main class="max-w-7xl mx-auto px-6 lg:px-8 py-32 pb-24">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
      
      {/* LEFT COLUMN */}
      <div class="lg:col-span-8 space-y-10">
        
        {/* Profile Header */}
        <div class="flex flex-col sm:flex-row gap-6 items-start">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-2xl overflow-hidden bg-raised shrink-0 shadow-sm">
            <img src={therapist.image} alt={therapist.name} class="w-full h-full object-cover" />
          </div>
          
          <div class="flex-1 pt-1">
            <h1 class=" text-3xl sm:text-4xl font-medium text-ink tracking-tight mb-2">
              {therapist.name}
            </h1>
            <p class="text-sm text-ink-soft/90 mb-3">
              {therapist.credentials} 
              <span class="text-ink-soft/50">({therapist.pronouns})</span>
            </p>
            
            <div class="flex items-center gap-3 flex-wrap">
              {therapist.verified && (
                <span class="inline-flex items-center gap-1.5 text-xs font-medium text-sage">
                  <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 003.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/>
                  </svg>
                  Verified by Circle Share
                </span>
              )}
              {therapist.endorsed > 0 && (
                <span class="text-xs text-ink-soft/70 flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"/>
                  </svg>
                  {therapist.endorsed} Endorsed
                </span>
              )}
            </div>
          </div>
        </div>

        {/* Bio */}
        <div class="space-y-6">
          {therapist.bio.map((paragraph, i) => (
            <p class="text-base font-light text-ink-soft leading-[1.8]">
              {i === 0 && (
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-raised text-ink-soft/70 mr-2 align-middle">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                </span>
              )}
              {paragraph}
            </p>
          ))}
        </div>

        <div class="h-px bg-cream/60" />

        {/* NEW: Certificates & Credentials Section */}
        {therapist.certificates && therapist.certificates.length > 0 && (
          <section>
            <div class="flex items-center justify-between mb-6">
              <div>
                <h2 class=" text-2xl font-medium text-ink mb-1">
                  Credentials & Licensure
                </h2>
                <p class="text-sm text-ink-soft/70 font-light">
                  Verified professional certifications
                </p>
              </div>
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-raised rounded-full text-xs font-medium text-ink-soft/90">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
                Confidential
              </span>
            </div>

            <div class="space-y-4">
              {therapist.certificates.map((cert) => (
                <div class="bg-white rounded-xl border border-line p-5 hover:border-line transition-colors">
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-1">
                        <h3 class="font-medium text-ink text-sm">{cert.title}</h3>
                        <span class="px-2 py-0.5 bg-sage/10 text-sage text-[10px] font-semibold uppercase tracking-wide rounded-full">
                          {cert.status}
                        </span>
                      </div>
                      <p class="text-xs text-ink-soft/70 mb-2">{cert.issuer}</p>
                      <div class="flex items-center gap-4 text-xs text-ink-soft/50">
                        <span class="flex items-center gap-1">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-5 4h5m-5 4h5"/>
                          </svg>
                          License: {cert.license}
                        </span>
                        <span class="flex items-center gap-1">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                          </svg>
                          Issued {cert.year}
                        </span>
                      </div>
                    </div>
                    <a 
                      href={cert.url} 
                      class="shrink-0 w-9 h-9 rounded-full bg-canvas flex items-center justify-center text-ink-soft/70 hover:bg-ink hover:text-cream transition-all duration-300"
                      title="View certificate"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                    </a>
                  </div>
                </div>
              ))}
            </div>

            <p class="text-xs text-ink-soft/50 mt-4 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              License details are verified and securely stored. Full documentation available upon request.
            </p>
          </section>
        )}

        <div class="h-px bg-cream/60" />

        {/* Circles by this Therapist */}
        <section>
          <h2 class=" text-2xl font-medium text-ink mb-2">
            Circles facilitated by {therapist.name.split(' ')[0]}
          </h2>
          <p class="text-sm text-ink-soft/70 font-light mb-8">
            Join a small group session led by this therapist
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {therapistCircles.map(circle => (
              <CircleCard {...circle} />
            ))}
          </div>
        </section>

      </div>

      {/* RIGHT COLUMN — Sidebar (unchanged) */}
      <div class="lg:col-span-4 space-y-6">
        
        {/* Let's Connect */}
        <div class="bg-white rounded-2xl border border-line p-6 shadow-sm">
          <h3 class="text-xs font-bold tracking-[0.15em] uppercase text-ink-soft/50 mb-4">Let's Connect</h3>
          <a href={`tel:${therapist.phone}`} class="flex items-center gap-3 text-2xl font-medium text-ink hover:text-sage transition-colors mb-5">
            <svg class="w-5 h-5 text-ink-soft/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            {therapist.phone}
          </a>
          <a href="#" class="block w-full text-center px-6 py-3.5 bg-ink text-cream text-sm font-medium rounded-full hover:bg-sage transition-colors duration-300 shadow-sm">
            Email Me
          </a>
          <a href="#" class="mt-3 block w-full text-center px-6 py-3.5 border border-line text-ink-2 text-sm font-medium rounded-full hover:border-line hover:bg-white transition-colors duration-300">
            Share Profile
          </a>
        </div>

        {/* Practice at a Glance */}
        <div class="bg-white rounded-2xl border border-line p-6 shadow-sm">
          <h3 class=" text-lg font-medium text-ink mb-6">My Practice at a Glance</h3>
          <div class="space-y-5">
            
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-canvas flex items-center justify-center shrink-0 text-ink-soft/70">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <p class="text-sm font-medium text-ink">Available both in-person and online</p>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-canvas flex items-center justify-center shrink-0 text-ink-soft/70">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-ink">{therapist.practiceName}</p>
                <p class="text-sm font-light text-ink-soft/70 leading-relaxed mt-0.5">{therapist.address}</p>
                <a href={`tel:${therapist.phone}`} class="text-sm text-ink-soft/90 hover:text-sage transition-colors mt-1 inline-block">{therapist.phone}</a>
              </div>
            </div>

            <div class="h-px bg-raised" />

            <div class="flex flex-wrap gap-2">
              <a href="#" class="px-4 py-2 border border-line rounded-full text-xs font-medium text-ink-soft/90 hover:border-line hover:text-ink transition-all">Email Me</a>
              <a href="#" class="px-4 py-2 border border-line rounded-full text-xs font-medium text-ink-soft/90 hover:border-line hover:text-ink transition-all">My website</a>
              <a href="#" class="px-4 py-2 border border-line rounded-full text-xs font-medium text-ink-soft/90 hover:border-line hover:text-ink transition-all">Share</a>
            </div>

            <div class="h-px bg-raised" />

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-canvas flex items-center justify-center shrink-0 text-ink-soft/70">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
              </div>
              <p class="text-sm text-ink-soft leading-relaxed">
                I specialize in {therapist.specialties.join(', ')} <a href="#" class="text-sage hover:underline underline-offset-4 ml-1">›</a>
              </p>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-canvas flex items-center justify-center shrink-0 text-ink-soft/70">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <p class="text-sm text-ink-soft">
                <span class="font-medium text-ink">{therapist.cost}</span> Per Session
                {therapist.acceptsInsurance && (
                  <span>, I accept insurance <a href="#" class="text-sage hover:underline underline-offset-4">›</a></span>
                )}
              </p>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-canvas flex items-center justify-center shrink-0 text-ink-soft/70">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
              </div>
              <p class="text-sm text-ink-soft">{therapist.sessionType} <a href="#" class="text-sage hover:underline underline-offset-4">›</a></p>
            </div>

          </div>
        </div>

      </div>
    </div>

  </main>
</Layout>