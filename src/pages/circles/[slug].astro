---
import Layout from '../../layouts/Layout.astro';
import { circles } from '../../data/circles';

export async function getStaticPaths() {
  return circles.map(circle => ({
    params: { slug: circle.id },
    props: { circle }
  }));
}

const { circle } = Astro.props;

const nextDate = new Date(circle.nextSession);
const dateStr = nextDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
const timeStr = nextDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });

export const prerender = true;
---

<Layout title={`${circle.title} — Circle Share`}>
  <main class="pb-24">

    {/* Hero Banner — Full Bleed Image */}
    <section class="relative w-full h-[400px] md:h-[480px] lg:h-[520px] overflow-hidden">
      {/* Background Image */}
      <div class="absolute inset-0">
        <img 
          src={circle.image} 
          alt={circle.title}
          class="w-full h-full object-cover"
        />
        {/* Dark Gradient Overlay — heavier on left for text readability */}
        <div class="absolute inset-0 bg-gradient-to-r from-ink/80 via-warm-900/50 to-transparent" />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/60 via-transparent to-transparent" />
      </div>

      {/* Content */}
      <div class="relative h-full max-w-7xl mx-auto px-6 lg:px-8 flex flex-col justify-end pb-12 md:pb-16">
        <div class="flex items-end justify-between gap-6">
          
          {/* Left: Text */}
          <div class="max-w-xl">
            <p class="text-sm text-cream/80 font-medium mb-3">
              with {circle.facilitator.name}
            </p>
            <h1 class=" text-4xl md:text-5xl lg:text-6xl font-medium text-white leading-[0.95] mb-4">
              {circle.title}
            </h1>
            <p class="text-base md:text-lg font-medium text-cream/90 leading-relaxed max-w-md">
              {circle.goal}
            </p>
          </div>

          {/* Right: Share Button */}
          <button 
            onclick="navigator.share?.({title: document.title, url: window.location.href}) || alert('Copy this URL to share')"
            class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 bg-white/10 backdrop-blur-md border border-white/20 text-white text-sm font-medium rounded-full hover:bg-white/20 transition-all duration-300 shrink-0"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
            </svg>
            Share
          </button>
          
        </div>
      </div>
    </section>
<div class="h-1 bg-warm-600 my-12"></div>
    <div class="max-w-4xl mx-auto px-6 -mt-8">
      
      {/* Quick Info Bar */}
      <div class="bg-white rounded-2xl border border-line p-6 shadow-sm flex flex-wrap items-center gap-6 lg:gap-10">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-ink-soft/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <span class="text-sm font-medium text-ink-soft">{circle.format}</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-ink-soft/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <span class="text-sm font-medium text-ink-soft">{circle.frequency}</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-ink-soft/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <span class="text-sm font-medium text-ink-soft">
            {circle.currentMembers} / {circle.maxMembers} Members
          </span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-ink-soft/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-sm font-medium text-ink-soft">
            Next: {dateStr} • {timeStr}
          </span>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 mt-12">
        
        {/* LEFT: Main Content */}
        <div class="lg:col-span-2 space-y-12">
          
          {/* Who Is It For */}
          <section>
            <h2 class=" text-2xl font-medium text-ink mb-4">Who this circle is for</h2>
            <p class="text-base font-medium text-ink-soft/90 leading-[1.8]">
              {circle.whoIsItFor}
            </p>
          </section>

          {/* Challenges */}
          <section>
            <h2 class=" text-2xl font-medium text-ink mb-4">Challenges we address</h2>
            <div class="flex flex-wrap gap-2">
              {circle.challenges.map(tag => (
                <span class="px-4 py-2 bg-raised text-ink-soft text-sm font-medium rounded-full border border-line">
                  {tag}
                </span>
              ))}
            </div>
          </section>

          {/* What You'll Work On */}
          <section>
            <h2 class=" text-2xl font-medium text-ink mb-4">What you'll work on</h2>
            <ul class="space-y-3">
              {circle.whatYoullWorkOn.map(item => (
                <li class="flex items-start gap-3">
                  <span class="w-5 h-5 rounded-full bg-sage/10 flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-3 h-3 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                    </svg>
                  </span>
                  <span class="text-base font-medium text-ink-soft">{item}</span>
                </li>
              ))}
            </ul>
          </section>

          {/* Session Structure */}
          <section>
            <h2 class=" text-2xl font-medium text-ink mb-4">How sessions are structured</h2>
            <div class="space-y-4">
              {circle.sessionStructure.map((step, i) => (
                <div class="flex items-center gap-4 p-4 bg-white rounded-xl border border-line">
                  <span class="w-8 h-8 rounded-full bg-ink text-cream flex items-center justify-center text-xs font-medium shrink-0">
                    {i + 1}
                  </span>
                  <div>
                    <p class="text-sm font-medium text-ink">{step.activity}</p>
                    <p class="text-xs text-ink-soft/50">{step.duration}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* Community Rules */}
          <section>
            <h2 class=" text-2xl font-medium text-ink mb-4">Community agreements</h2>
            <div class="grid grid-cols-2 gap-3">
              {circle.rules.map(rule => (
                <div class="flex items-center gap-3 p-4 bg-canvas rounded-xl">
                  <svg class="w-5 h-5 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span class="text-sm font-medium text-ink-soft">{rule}</span>
                </div>
              ))}
            </div>
          </section>

        </div>

        {/* RIGHT: Sidebar */}
        <div class="space-y-6">
          
          {/* Facilitator Card */}
          <div class="bg-white rounded-2xl border border-line p-6 shadow-sm">
            <p class="text-xs font-medium tracking-wider uppercase text-ink-soft/50 mb-4">Your facilitator</p>
            <div class="flex items-center gap-4 mb-4">
              <div class="w-16 h-16 rounded-xl overflow-hidden bg-raised">
                <img src={circle.facilitator.photo} alt={circle.facilitator.name} class="w-full h-full object-cover" />
              </div>
              <div>
                <h3 class=" text-lg font-medium text-ink">{circle.facilitator.name}</h3>
                <p class="text-xs text-ink-soft/70">{circle.facilitator.credentials}</p>
              </div>
            </div>
            <div class="space-y-2 text-sm">
              <p class="text-ink-soft/90"><span class="text-ink-soft/50">{circle.facilitator.experience}</span> experience</p>
              <p class="text-ink-soft/90"><span class="text-ink-soft/50">{circle.facilitator.specialization}</span></p>
            </div>
            <p class="text-sm font-medium text-ink-soft/90 leading-relaxed mt-4">
              {circle.facilitator.bio}
            </p>
          </div>

          {/* Join Card */}
          <div class="bg-ink rounded-2xl p-6 text-cream">
            <p class="text-xs font-medium tracking-wider uppercase text-mist mb-2">Join this circle</p>
            <p class=" text-3xl font-medium mb-1">{circle.price}</p>
            <p class="text-sm text-mist mb-6">{circle.pricingModel}</p>
            
            <div class="space-y-3 mb-6">
              <div class="flex items-center gap-2 text-sm text-cream">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {circle.level}
              </div>
              <div class="flex items-center gap-2 text-sm text-cream">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {circle.frequency} sessions
              </div>
              <div class="flex items-center gap-2 text-sm text-cream">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {circle.maxMembers - circle.currentMembers} spots left
              </div>
            </div>

            <button class="w-full py-3.5 bg-cream text-ink text-sm font-medium rounded-full hover:bg-white transition-colors duration-300">
              Join Circle
            </button>
            <p class="text-xs text-ink-soft/50 text-center mt-3">
              Next session {dateStr} at {timeStr}
            </p>
          </div>

          {/* Level Badge */}
          <div class="bg-white rounded-2xl border border-line p-6 text-center">
            <p class="text-xs font-medium tracking-wider uppercase text-ink-soft/50 mb-2">Experience Level</p>
            <p class=" text-xl font-medium text-ink">{circle.level}</p>
          </div>

        </div>
      </div>

    </div>
  </main>
</Layout>