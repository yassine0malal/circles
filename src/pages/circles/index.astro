---
import { circles } from "../../data/circles";
import Layout from "../../layouts/Layout.astro";

const filters = [
  "All",
  "Grief & Loss",
  "Addiction & Recovery",
  "Anxiety & stress",
  "Relationships",
  "Life Transition"
];
---

<Layout title="Circles">
  <main class="max-w-7xl mx-auto px-6 lg:px-8 pb-24">

    {/* Hero */}
    <section class="text-center pt-16 pb-12">
      <h1 class="font-serif text-4xl md:text-5xl font-medium text-warm-900 mb-4 tracking-tight">
        Future of healing is in community
      </h1>
      <p class="text-warm-500 max-w-2xl mx-auto leading-relaxed text-sm md:text-base">
        Circle Share brings people together in small, intentional circles facilitated by licensed therapists.
        <br class="hidden md:block" />
        Explore circles for support, reflection, and growth.
      </p>
    </section>

    {/* Search */}
    <div class="max-w-3xl mx-auto mb-10">
      <div class="relative group">
        <input 
          type="text" 
          placeholder="Search circles, themes, facilitators..." 
          class="w-full border border-warm-300 rounded-[8px] py-4 pl-6 pr-14 text-sm text-warm-900 placeholder:text-warm-400 bg-white focus:outline-none focus:border-olive focus:ring-4 focus:ring-olive/10 transition-all duration-300"
        />
        <svg 
          class="absolute right-5 top-1/2 -translate-y-1/2 w-5 h-5 text-warm-400 group-focus-within:text-olive transition-colors" 
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24"
        >
          <circle cx="11" cy="11" r="8" stroke-width="1.5"/>
          <path d="M21 21l-4.35-4.35" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
    </div>

    {/* Filters */}
    <div class="flex flex-wrap items-center gap-3 mb-12 max-w-4xl mx-auto border p-3 rounded-[8px]">
      {filters.map((filter, i) => (
        <button 
          class={`px-5 py-2.5 rounded-[4px] text-sm font-medium transition-all duration-300 ${
            i === 0 
              ? 'bg-warm-800 text-cream hover:bg-olive' 
              : 'border border-warm-200 text-warm-600 hover:border-warm-400 hover:text-warm-900'
          }`}
        >
          {filter}
        </button>
      ))}
    </div>

    {/* Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {circles.map(circle => {
        const nextDate = new Date(circle.nextSession);
        const dateStr = nextDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        const timeStr = nextDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
        const spotsStr = `${circle.currentMembers}/${circle.maxMembers}`;
        
        return (
          <a href={`/circles/${circle.id}`} class="group block">
            <article class="rounded-[8px] border border-warm-100 overflow-hidden hover:bg-[#EEE4D7] hover:shadow-warm-900/5 hover:-translate-y-1 transition-all duration-500 cursor-pointer">
              
              {/* Image */}
              <div class="relative overflow-hidden p-4">
                <img 
                  src={circle.image} 
                  alt={circle.title}
                  class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-700 rounded-[8px]"
                  loading="lazy"
                />
                <div class="absolute top-6 right-4">
                  <span class="inline-flex items-center gap-1.5 bg-white/90 backdrop-blur-sm text-warm-800 text-xs font-medium px-3 py-1.5 rounded-full shadow-sm">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="10" stroke-width="1.5"/>
                      <path d="M12 6v6l4 2" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    {circle.price}
                  </span>
                </div>
              </div>

              {/* Content */}
              <div class="p-5">
                <div class="flex items-start gap-2 mb-3">
                  <h3 class="font-bona text-2xl font-medium text-warm-900 leading-snug group-hover:text-olive transition-colors">
                    {circle.title}
                  </h3>
                  <span class="shrink-0 mt-1 px-2 py-0.5 bg-warm-100 text-warm-600 text-[10px] font-medium rounded-full uppercase tracking-wide">
                    {circle.category}
                  </span>
                </div>

                {/* Facilitator */}
                <div class="flex items-center gap-2 mb-3">
                  <div class="w-6 h-6 rounded-full bg-warm-200 flex items-center justify-center overflow-hidden">
                    <img
                      src={circle.facilitator.photo}
                      alt={circle.facilitator.name}
                      class="w-5 h-5 rounded-full object-cover"
                    />
                  </div>
                  <div class="leading-tight">
                    <span class="text-sm font-medium text-warm-800">{circle.facilitator.name}</span>
                    <span class="text-xs text-warm-400 block">{circle.facilitator.credentials}</span>
                  </div>
                </div>

                {/* Challenges */}
                <div class="flex flex-wrap gap-1.5 mb-4">
                  {circle.challenges.map(tag => (
                    <span class="px-2 py-1 bg-warm-50 text-warm-600 text-[11px] font-light rounded-md border border-warm-100">
                      {tag}
                    </span>
                  ))}
                </div>

                {/* Meta row */}
                <div class="flex items-center gap-4 mb-3 text-xs text-warm-400">
                  <span class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <rect x="3" y="4" width="18" height="18" rx="2" stroke-width="1.5"/>
                      <path d="M16 2v4M8 2v4M3 10h18" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    {dateStr}
                  </span>
                  <span class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="10" stroke-width="1.5"/>
                      <path d="M12 6v6l4 2" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    {timeStr}
                  </span>
                  <span class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke-width="1.5"/>
                      <circle cx="9" cy="7" r="4" stroke-width="1.5"/>
                      <path d="M23 21v-2a4 4 0 00-3-3.87" stroke-width="1.5"/>
                      <path d="M16 3.13a4 4 0 010 7.75" stroke-width="1.5"/>
                    </svg>
                    {spotsStr}
                  </span>
                </div>

                {/* Location */}
                <div class="flex items-center gap-1.5 text-xs text-warm-400">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke-width="1.5"/>
                    <circle cx="12" cy="10" r="3" stroke-width="1.5"/>
                  </svg>
                  {circle.format}
                </div>
              </div>
            </article>
          </a>
        );
      })}
    </div>

  </main>
</Layout>