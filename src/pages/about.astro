---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About — Circle Share">
  
  {/* ═══ Hero ═══ */}
  <div class="relative overflow-hidden bg-[radial-gradient(120%_90%_at_50%_0%,var(--color-ink)_0%,var(--color-ink-2)_58%,#1F1728_100%)] text-cream">
    <div class="pointer-events-none absolute left-1/2 top-[40%] h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 blur-[6px]"
      style="background: radial-gradient(circle, rgba(224,163,92,.22) 0%, rgba(193,111,114,.10) 38%, transparent 66%);"
    />
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 pt-32 pb-20 text-center">
      <span class="inline-block text-amber text-sm font-semibold tracking-[0.16em] uppercase mb-4">Our Story</span>
      <h1 class="font-[Fraunces] font-light text-[clamp(2.5rem,5vw,4rem)] leading-[1.05] tracking-[-0.03em] mb-6">
        Healing is better<br>when it's <em class="italic text-rose">shared</em>.
      </h1>
     <div class="max-w-[600px] mx-auto mt-4 bg-cream/5 backdrop-blur-sm border border-cream/10 rounded-2xl p-8 md:p-10">
  <svg class="w-8 h-8 text-rose/60 mb-4 mx-auto" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
  </svg>
  <p class="text-lg md:text-xl text-cream/90 leading-[1.7] font-light">
    Circle Share was built on a simple belief: finding support shouldn't require surrendering your <span class="text-amber font-medium">privacy</span>, your <span class="text-amber font-medium">data</span>, or a cut of your <span class="text-amber font-medium">paycheck</span>.
  </p>
</div>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-6 lg:px-8 pb-24">

    {/* ═══ Mission ═══ */}
    <section class="py-20 grid grid-cols-1 md:grid-cols-3 gap-10">
      <div class="bg-white rounded-2xl border border-line p-8 text-center hover:shadow-lg hover:shadow-ink/5 transition-all duration-300">
        <div class="w-12 h-12 rounded-full bg-rose/10 flex items-center justify-center mx-auto mb-5 text-rose">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <h3 class="text-xl font-medium text-ink mb-3">Privacy First</h3>
        <p class="text-sm text-ink-soft/80 leading-relaxed">
          No trackers. No pixels. No analytics that follow you around the internet. We count visits without ever knowing it's you.
        </p>
      </div>

      <div class="bg-white rounded-2xl border border-line p-8 text-center hover:shadow-lg hover:shadow-ink/5 transition-all duration-300">
        <div class="w-12 h-12 rounded-full bg-sage/10 flex items-center justify-center mx-auto mb-5 text-sage">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-medium text-ink mb-3">Direct Connection</h3>
        <p class="text-sm text-ink-soft/80 leading-relaxed">
          We introduce you to therapists and healers, then step out of the way. Book and pay directly — we never touch the relationship or the money.
        </p>
      </div>

      <div class="bg-white rounded-2xl border border-line p-8 text-center hover:shadow-lg hover:shadow-ink/5 transition-all duration-300">
        <div class="w-12 h-12 rounded-full bg-amber/15 flex items-center justify-center mx-auto mb-5 text-amber">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-xl font-medium text-ink mb-3">Zero Commission</h3>
        <p class="text-sm text-ink-soft/80 leading-relaxed">
          Therapists keep 100% of what they earn. No platform fees, no subscription tiers, no hidden costs passed on to you.
        </p>
      </div>
    </section>

    {/* ═══ Story ═══ */}
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center py-12">
      <div>
        <span class="text-sage text-sm font-semibold tracking-[0.12em] uppercase mb-3 block">Why we built this</span>
        <h2 class="font-[Fraunces] font-light text-[clamp(1.8rem,3.5vw,2.6rem)] leading-[1.1] tracking-[-0.025em] text-ink mb-6">
          A directory that treats <em class="italic text-rose">people</em> like people.
        </h2>
        <div class="space-y-4 text-ink-soft/90 leading-relaxed">
          <p>
            Most therapy directories are built on surveillance. They sell your clicks, require invasive intake forms, and take a percentage of every session.
          </p>
          <p>
            We think that's wrong. Circle Share is a quiet, respectful space where licensed clinicians and coaches can list their circles, set their own rates, and connect with people who need them — without a middleman monetizing the exchange.
          </p>
          <p>
            Whether you're looking for a grief circle in Brooklyn or a virtual ADHD group in Austin, you should be able to find it, see who's running it, and join directly. No friction. No tracking. No fine print.
          </p>
        </div>
      </div>
      <div class="relative">
        <div class="absolute -inset-4 bg-[radial-gradient(circle_at_center,rgba(193,111,114,0.08),transparent_70%)] rounded-3xl" />
        <div class="relative bg-raised/50 rounded-2xl border border-line p-8 lg:p-10">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-xl bg-ink-2 flex items-center justify-center">
              <svg width="34" height="34" viewBox="0 0 34 34" fill="none">
                <circle cx="13" cy="17" r="9" stroke="var(--color-rose)" stroke-width="2"/>
                <circle cx="21" cy="17" r="9" stroke="var(--color-sage)" stroke-width="2"/>
              </svg>
            </div>
            <div>
              <p class="font-medium text-ink text-lg">Circle Share</p>
              <p class="text-sm text-ink-soft/70">Founded in 2025</p>
            </div>
          </div>
          <blockquote class="font-[Fraunces] text-xl text-ink-soft italic leading-relaxed">
            "The overlap of two rings is where belonging happens. We just built the space for the overlap."
          </blockquote>
        </div>
      </div>
    </section>

    {/* ═══ Contact Form ═══ */}
    <section class="mt-16">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-10">
          <span class="text-sage text-sm font-semibold tracking-[0.12em] uppercase mb-3 block">Get in Touch</span>
          <h2 class="font-[Fraunces] font-light text-[clamp(1.8rem,3.5vw,2.6rem)] leading-[1.1] tracking-[-0.025em] text-ink mb-4">
            Have a question? <em class="italic text-rose">Write to us.</em>
          </h2>
          <p class="text-ink-soft/80">
            For press, partnerships, or feedback — we read every message.
          </p>
        </div>

        <form 
          action="/api/contact" 
          method="POST" 
          class="bg-white rounded-2xl border border-line p-8 lg:p-10 space-y-6"
          id="contact-form"
        >
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-ink mb-2">Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required
                class="w-full px-4 py-3 rounded-xl border border-line bg-raised text-ink placeholder:text-ink-soft/40 focus:outline-none focus:border-sage focus:ring-4 focus:ring-sage/10 transition-all"
                placeholder="Your name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-ink mb-2">Email</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 rounded-xl border border-line bg-raised text-ink placeholder:text-ink-soft/40 focus:outline-none focus:border-sage focus:ring-4 focus:ring-sage/10 transition-all"
                placeholder="you@example.com"
              />
            </div>
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-ink mb-2">Subject</label>
            <select 
              id="subject" 
              name="subject"
              class="w-full px-4 py-3 rounded-xl border border-line bg-raised text-ink focus:outline-none focus:border-sage focus:ring-4 focus:ring-sage/10 transition-all appearance-none cursor-pointer"
            >
              <option value="general">General question</option>
              <option value="therapist">I'm a therapist / facilitator</option>
              <option value="press">Press inquiry</option>
              <option value="partnership">Partnership</option>
              <option value="feedback">Feedback</option>
              <option value="other">Something else</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-ink mb-2">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="5" 
              required
              class="w-full px-4 py-3 rounded-xl border border-line bg-raised text-ink placeholder:text-ink-soft/40 focus:outline-none focus:border-sage focus:ring-4 focus:ring-sage/10 transition-all resize-y"
              placeholder="Tell us what's on your mind..."
            ></textarea>
          </div>

          <div class="flex items-start gap-3">
            <div class="relative mt-0.5">
              <input type="checkbox" id="privacy" name="privacy" required class="peer sr-only" />
              <div class="w-5 h-5 rounded border border-line bg-raised peer-checked:bg-rose peer-checked:border-rose transition-all flex items-center justify-center">
                <svg class="w-3 h-3 text-cream opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
            </div>
            <label for="privacy" class="text-sm text-ink-soft/80 leading-snug cursor-pointer">
              I agree that my details will be stored for the purpose of responding to my inquiry. No data is shared with third parties.
            </label>
          </div>

          <button 
            type="submit"
            class="w-full md:w-auto px-8 py-3.5 bg-[linear-gradient(160deg,var(--color-rose)_0%,var(--color-rose-ink)_50%,var(--color-amber)_100%)] text-cream rounded-full text-sm font-medium hover:bg-rose transition-all duration-300 shadow-lg shadow-ink/10 active:scale-[0.98]"
          >
            Send Message
          </button>
        </form>

        {/* Success state (hidden by default) */}
        <div id="form-success" class="hidden bg-sage/10 rounded-2xl border border-sage/20 p-8 lg:p-10 text-center">
          <div class="w-14 h-14 rounded-full bg-sage flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-cream" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="text-xl font-medium text-ink mb-2">Message sent</h3>
          <p class="text-ink-soft/80">We'll get back to you as soon as we can.</p>
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Simulate submission — replace with actual API call
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = btn.textContent;
    btn.textContent = 'Sending...';
    btn.disabled = true;
    
    await new Promise(r => setTimeout(r, 1200));
    
    form.classList.add('hidden');
    success.classList.remove('hidden');
    success.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
</script>