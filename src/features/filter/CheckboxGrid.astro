---
import CheckboxItem from "./CheckboxItem.astro";

export interface Props {
  items: { id: string; label: string }[];
  type: "specialties" | "insurance" | "therapy" | "language";
  initialVisible?: number;
}

const { items, type, initialVisible = 15 } = Astro.props;
const itemClass = `${type}-item`;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
  {items.map((item, index) => (
    <div class={`${itemClass} ${index >= initialVisible ? 'hidden' : ''}`} data-index={index}>
      <CheckboxItem id={item.id} label={item.label} />
    </div>
  ))}
</div>
<button 
  class="toggle-more-btn mt-4 text-sm font-medium text-sage hover:text-ink transition-colors"
  type="button"
  data-type={type}
>
  Show more
</button>