<section class="py-24 px-8 bg-warm-100">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <p class="text-xs font-light tracking-[0.3em] uppercase text-warm-500 mb-4">Introduction</p>
      <h2 class=" text-4xl md:text-5xl font-semibold text-warm-900 leading-tight">
        Welcome to a space<br />dedicated to your <span class="italic text-olive">well-being</span>
      </h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 md:gap-8">
      {[
        { value: '80%', label: 'Emotional well-being' },
        { value: '10+', label: 'Thoughtfully designed circles' },
        { value: '300+', label: 'Shared moments of reflection' },
        { value: '50%', label: 'Return to continue their journey' },
      ].map(stat => (
        <div class="text-center">
          <p class="font-serif text-5xl md:text-6xl font-medium text-olive mb-3">{stat.value}</p>
          <p class="text-sm font-light text-warm-500 leading-relaxed max-w-[140px] mx-auto">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>