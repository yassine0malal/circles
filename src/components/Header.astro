---
import "../styles/global.css";
const navLinks = [
  { 
    label: 'Our Philosophy', 
    href: '/our-philosophy'
  },
  { 
    label: 'Therapists', 
    href: '/therapists',
    mega: {
      type: 'search', // ← special layout type
      cities: [
        { label: "Austin, TX", href: "/therapists?location=austin-tx" },
        { label: "Brooklyn, NY", href: "/therapists?location=brooklyn-ny" },
        { label: "Chicago, IL", href: "/therapists?location=chicago-il" },
        { label: "Denver, CO", href: "/therapists?location=denver-co" },
        { label: "Houston, TX", href: "/therapists?location=houston-tx" },
        { label: "Los Angeles, CA", href: "/therapists?location=los-angeles-ca" },
        { label: "New York, NY", href: "/therapists?location=new-york-ny" },
        { label: "Portland, OR", href: "/therapists?location=portland-or" },
        { label: "San Diego, CA", href: "/therapists?location=san-diego-ca" },
        { label: "San Francisco, CA", href: "/therapists?location=san-francisco-ca" },
        { label: "Seattle, WA", href: "/therapists?location=seattle-wa" },
        { label: "Washington, DC", href: "/therapists?location=washington-dc" },
        { label: "Atlanta, GA", href: "/therapists?location=atlanta-ga" },
        { label: "Sacramento, CA", href: "/therapists?location=sacramento-ca" }
      ]
    }
  },
  { 
    label: 'Circles', 
    href: '/circles/',
    mega: {
      columns: [
        {
          title: 'By Topic',
          links: [
            { label: 'Grief & Loss', href: '/circles/grief', desc: 'Navigate loss together' },
            { label: 'Anxiety & Stress', href: '/circles/anxiety', desc: 'Find calm in community' },
            { label: 'Life Transitions', href: '/circles/transitions', desc: 'Change with support' },
            { label: 'Relationships', href: '/circles/relationships', desc: 'Connect more deeply' },
          ]
        },
        {
          title: 'By Format',
          links: [
            { label: 'Weekly Circles', href: '/circles/weekly', desc: 'Ongoing support' },
            { label: 'One-Time Sessions', href: '/circles/single', desc: 'Drop-in healing' },
            { label: 'Women Only', href: '/circles/women', desc: 'Safe women\'s space' },
            { label: 'Men Only', href: '/circles/men', desc: 'Brotherhood circles' },
          ]
        },
      ],
      featured: {
        image: 'https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=400&h=300&fit=crop',
        title: 'This Week\'s Circles',
        description: 'Browse upcoming sessions starting soon',
        href: '/circles'
      }
    }
  },
  { label: 'Contact', href: '/contact' },
];
---

<header 
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-700 ease-out"
>
  <div class="max-w-[1400px] mx-auto px-10 lg:px-16 relative">
    <div class="flex justify-between items-center h-20 lg:h-24 transition-all duration-700">
      
      {/* Logo */}
      <a href="/" class="flex items-center gap-4 group z-50 relative">
        <div class="w-20 h-20 lg:w-22 lg:h-22 rounded-full bg-warm-800 flex items-center justify-center transition-transform duration-500 group-hover:scale-105 border-2 border-[#000]">

            <div class="w-12 h-12 lg:w-22 lg:h-22 rounded-full bg-warm-800 flex items-center justify-center transition-transform duration-500 group-hover:scale-105 border-2 border-[#fff]">
              <span class="text-cream font-serif text-base lg:text-lg font-medium tracking-tight ">Circles</span>
            </div>
          
          </div>

        <div class="flex flex-col">
          <span class="font-serif text-xl lg:text-2xl font-medium tracking-tight text-warm-900 leading-none group-hover:text-olive transition-colors duration-500">
            Circle Share
          </span>
          <span class="text-[10px] lg:text-xs font-light tracking-[0.25em] uppercase text-warm-400 mt-1 leading-none">
            Healing Together
          </span>
        </div>
      </a>

      {/* Desktop Navigation */}
      <nav class="hidden lg:flex items-center h-full">
        {navLinks.map((link, index) => (
          <div class="relative h-full flex items-center">
            {link.mega ? (
              <button
                class="mega-trigger nav-item relative px-6 h-full flex items-center gap-2 text-[15px] font-bold tracking-wide text-warm-500 hover:text-warm-900 transition-colors duration-500 group"
                data-index={index}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {link.label}
                <svg 
                  class="mega-arrow w-3.5 h-3.5 text-warm-400 transition-transform duration-300" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-10 9-7-9"/>
                </svg>
                <span class="absolute bottom-5 left-6 right-6 h-[1.5px] bg-olive scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out origin-left" />
              </button>
            ) : (
              <a
                href={link.href}
                class="nav-item relative px-6 h-full flex items-center text-[15px] font-bold tracking-wide text-warm-500 hover:text-warm-900 transition-colors duration-500 group"
              >
                {link.label}
                <span class="absolute bottom-5 left-6 right-6 h-[1.5px] bg-olive scale-x-0 group-hover:scale-x-100 transition-transform duration-500 ease-out origin-left" />
              </a>
            )}
          </div>
        ))}
      </nav>

      {/* CTA + Mobile Toggle */}
      <div class="flex items-center gap-6 z-50 relative">
        <a 
          href="/login" 
          class="hidden sm:inline-flex items-center gap-2 px-8 py-3 bg-warm-800 text-cream text-[13px] font-light tracking-[0.15em] uppercase rounded-[6px] hover:bg-olive transition-all duration-500 hover:shadow-lg hover:shadow-warm-800/20 hover:-translate-y-0.5"
        >
          Get Started
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        
        <button 
          id="mobile-menu-btn"
          class="lg:hidden flex flex-col gap-1.5 p-2 group relative"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <span id="menu-line-1" class="w-6 h-[1.5px] bg-warm-800 transition-all duration-500" />
          <span id="menu-line-2" class="w-4 h-[1.5px] bg-warm-800 transition-all duration-500" />
          <span id="menu-line-3" class="w-5 h-[1.5px] bg-warm-800 transition-all duration-500" />
        </button>
      </div>
    </div>
  </div>

  {/* Mega Menu Panels */}
  <div 
    id="mega-menu-container"
    class="absolute top-full left-0 right-0 opacity-0 invisible translate-y-4 transition-all duration-500 ease-out pointer-events-none"
  >
    <div class="max-w-[1400px] mx-auto px-10 lg:px-16 pt-4">
      <div class="bg-cream/95 backdrop-blur-xl border border-warm-200/50 rounded-2xl shadow-2xl shadow-warm-900/5 overflow-hidden">
        
        {navLinks.map((link, index) => link.mega && (
          <div 
            class="mega-panel hidden"
            data-panel={index}
          >
            {/* THERAPISTS SEARCH LAYOUT */}
            {link.mega.type === 'search' && (
              <div class="p-10 lg:p-12">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                  
                  {/* Left: Search Form */}
                  <div class="lg:col-span-7 space-y-6">
                    <div class="space-y-2">
                      <h2 class="font-serif text-2xl font-medium text-warm-900 tracking-tight">Find a Therapist</h2>
                      <p class="text-sm font-normal text-warm-500">Enter your location to discover verified therapists in your area.</p>
                    </div>
                    
                    <form action="/circle" method="GET" class="flex flex-col sm:flex-row items-stretch w-full border border-warm-300/80 rounded-2xl sm:rounded-full bg-white p-1.5 focus-within:border-olive focus-within:ring-4 focus-within:ring-olive/10 transition-all duration-200">
                      
                      <div class="relative flex items-center border-b sm:border-b-0 sm:border-r border-warm-200">
                        <select name="type" class="w-full sm:w-auto bg-transparent text-warm-800 font-medium text-sm py-3.5 pl-5 pr-10 outline-none cursor-pointer appearance-none">
                          <option value="therapists">Therapists</option>
                          <option value="circles">Circles</option>
                          <option value="clinics">Clinics</option>
                        </select>
                        <div class="absolute right-4 pointer-events-none text-warm-400">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                      </div>

                      <div class="flex-1 relative flex items-center min-w-0">
                        <input 
                          type="text" 
                          name="geo"
                          required
                          placeholder="City or Zip" 
                          class="w-full py-3.5 px-5 text-sm text-warm-900 placeholder-warm-400 outline-none bg-transparent"
                        />
                      </div>

                      <button type="submit" class="bg-warm-800 hover:bg-olive text-cream font-medium text-sm px-7 py-3.5 sm:py-0 rounded-xl sm:rounded-full transition-colors duration-300 flex items-center justify-center gap-2 shadow-sm active:scale-[0.98]">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
                        </svg>
                        <span>Search</span>
                      </button>
                    </form>

                    <div class="flex items-center gap-2 pt-2 text-xs font-bold text-warm-500">
                      <span class="font-semibold text-warm-800">Therapists:</span>
                      <a href="/login" class="hover:text-olive hover:underline underline-offset-2 transition">Login</a>
                      <span class="text-warm-300">•</span>
                      <a href="/register" class="hover:text-olive hover:underline underline-offset-2 transition">Sign Up & Get Listed</a>
                    </div>
                  </div>

                  {/* Right: City Directory */}
                  <div class="lg:col-span-5 relative lg:pl-12">
                    <div class="hidden lg:block absolute left-0 top-0 bottom-0 w-px bg-warm-200/70"></div>
                    
                    <div class="space-y-4">
                      <h3 class="text-xs font-bold tracking-[0.2em] text-warm-600 uppercase">United States Directory</h3>
                      
                      <div class="grid grid-cols-2 gap-x-6 gap-y-3">
                        {link.mega.cities.map((city) => (
                          <a 
                            href={city.href} 
                            class="text-lg   hover:text-olive hover:underline underline-offset-4 decoration-warm-300 transition-colors py-0.5 truncate"
                          >
                            {city.label}
                          </a>
                        ))}
                      </div>
                    </div>
                  </div>

                </div>
              </div>
            )}

            {/* STANDARD COLUMNS LAYOUT (for Circles, etc.) */}
            {link.mega.type !== 'search' && (
              <div class="p-10 lg:p-12">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
                  
                  <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-10">
                  {link.mega.columns?.map(column => (
                    <div>
                      <h3 class="font-serif text-lg font-medium text-warm-900 mb-6 tracking-wide">
                        {column.title}
                      </h3>
                      <ul class="space-y-4">
                        {column.links.map(item => (
                          <li>
                            <a href={item.href} class="group/link block">
                              <span class="text-2xl font-light text-warm-700 group-hover/link:text-warm-900 transition-colors duration-300 block mb-0.5">
                                {item.label}
                              </span>
                              <span class="text-xl font-light text-warm-400 group-hover/link:text-warm-500 transition-colors duration-300">
                                {item.desc}
                              </span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}

                    {/* Premium "View More" Button — spans both columns */}
                    <div class="md:col-span-2 flex justify-center pt-6 mt-2 border-t border-warm-200/50">
                      <a 
                        href="/circles" 
                        class="inline-flex items-center gap-3 px-8 py-3.5 bg-warm-800 text-cream text-[13px] font-medium tracking-[0.1em] uppercase rounded-[8px] hover:bg-olive transition-all duration-500 hover:shadow-lg hover:shadow-warm-800/15 hover:-translate-y-0.5 group"
                      >
                        View all circles
                        <svg 
                          class="w-4 h-4 transition-transform duration-500 group-hover:translate-x-1" 
                          fill="none" 
                          stroke="currentColor" 
                          viewBox="0 0 24 24"
                        >
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                        </svg>
                      </a>
                    </div>
                  </div>

                  <div class="lg:col-span-4">
                    <a href={link.mega.featured?.href} class="group/feat block">
                      <div class="relative aspect-[4/3] rounded-xl overflow-hidden mb-5 bg-warm-200">
                        <img 
                          src={link.mega.featured?.image} 
                          alt={link.mega.featured?.title}
                          class="w-full h-full object-cover group-hover/feat:scale-105 transition-transform duration-700 ease-out"
                          loading="lazy"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-warm-900/30 to-transparent opacity-0 group-hover/feat:opacity-100 transition-opacity duration-500" />
                      </div>
                      <h4 class="font-serif text-xl font-medium text-warm-900 mb-2 group-hover/feat:text-olive transition-colors duration-300">
                        {link.mega.featured?.title}
                      </h4>
                      <p class="text-sm font-light text-warm-500 leading-relaxed">
                        {link.mega.featured?.description}
                      </p>
                      <span class="inline-flex items-center gap-2 mt-4 text-xs font-medium tracking-wide text-olive uppercase group-hover/feat:gap-3 transition-all duration-300">
                        Learn more
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                        </svg>
                      </span>
                    </a>
                  </div>

                </div>
              </div>
            )}
          </div>
        ))}

      </div>
    </div>
  </div>

  {/* Mobile Menu Overlay */}
  <div 
    id="mobile-menu"
    class="lg:hidden fixed inset-0 top-20 bg-warm-50/95 backdrop-blur-xl z-40 opacity-0 pointer-events-none transition-all duration-500 ease-out"
  >
    <nav class="flex flex-col items-center justify-center h-full gap-8">
      {navLinks.map((link, i) => (
        <a 
          href={link.href} 
          class="mobile-nav-link font-serif text-3xl font-medium text-warm-800 hover:text-olive transition-colors duration-300 opacity-0 translate-y-4"
          style={`transition-delay: ${i * 75}ms`}
        >
          {link.label}
        </a>
      ))}
      <a 
        href="/login" 
        class="mobile-nav-link mt-6 px-10 py-4 bg-warm-800 text-cream text-sm font-light tracking-[0.15em] uppercase rounded-[8px] hover:bg-olive transition-all duration-500 opacity-0 translate-y-4"
        style={`transition-delay: ${navLinks.length * 75}ms`}
      >
        Get Started
      </a>
    </nav>
  </div>

  {/* Header Background */}
  <div 
    id="header-bg"
    class="absolute inset-0 bg-warm-50/70 backdrop-blur-xl border-b border-warm-200/40 -z-10 transition-all duration-700 opacity-0"
  />
</header>

<div class="h-20 lg:h-24" />

<script>
  const header = document.getElementById('main-header');
  const headerBg = document.getElementById('header-bg');
  const megaContainer = document.getElementById('mega-menu-container');
  const megaTriggers = document.querySelectorAll('.mega-trigger');
  const megaPanels = document.querySelectorAll('.mega-panel');
  const megaArrows = document.querySelectorAll('.mega-arrow');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');
  const line1 = document.getElementById('menu-line-1');
  const line2 = document.getElementById('menu-line-2');
  const line3 = document.getElementById('menu-line-3');

  let activeMegaIndex = -1;
  let isMobileOpen = false;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      headerBg?.classList.remove('opacity-0');
      headerBg?.classList.add('opacity-100');
    } else {
      headerBg?.classList.remove('opacity-100');
      headerBg?.classList.add('opacity-0');
    }
  });

  megaTriggers.forEach((trigger) => {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      
      const index = parseInt(trigger.getAttribute('data-index') || '-1');
      const panel = document.querySelector(`.mega-panel[data-panel="${index}"]`);
      
      if (!panel) return;

      if (activeMegaIndex === index) {
        closeMegaMenu();
      } else {
        openMegaMenu(index);
      }
    });
  });

function openMegaMenu(index:number) {
  activeMegaIndex = index;
  
  // Update triggers — FIX: read data-index from DOM, not array index
  megaTriggers.forEach((t) => {
    const triggerIndex = parseInt(t.getAttribute('data-index') || '-1');
    const isActive = triggerIndex === index;
    
    t.setAttribute('aria-expanded', String(isActive));
    
    if (isActive) {
      t.classList.remove('text-warm-500');
      t.classList.add('text-warm-900');
    } else {
      t.classList.remove('text-warm-900');
      t.classList.add('text-warm-500');
    }
  });

  // Rotate arrows — FIX: match by data-index, not array position
  megaArrows.forEach((arrow) => {
    // Find the parent trigger's data-index
    const parentTrigger = arrow.closest('.mega-trigger');
    const parentIndex = parseInt(parentTrigger?.getAttribute('data-index') || '-1');
    
    if (parentIndex === index) {
      arrow.classList.add('rotate-180');
    } else {
      arrow.classList.remove('rotate-180');
    }
  });

  // Show container
  megaContainer?.classList.remove('opacity-0', 'invisible', 'translate-y-4', 'pointer-events-none');
  megaContainer?.classList.add('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');

  // Show correct panel
  megaPanels.forEach((panel) => {
    const panelIndex = parseInt(panel.getAttribute('data-panel') || '-1');
    if (panelIndex === index) {
      panel.classList.remove('hidden');
      panel.animate([
        { opacity: 0, transform: 'translateY(12px)' },
        { opacity: 1, transform: 'translateY(0)' }
      ], {
        duration: 400,
        easing: 'cubic-bezier(0.16, 1, 0.3, 1)',
        fill: 'forwards'
      });
    } else {
      panel.classList.add('hidden');
    }
  });
}

function closeMegaMenu() {
  activeMegaIndex = -1;
  
  // Reset all triggers
  megaTriggers.forEach((t) => {
    t.setAttribute('aria-expanded', 'false');
    t.classList.remove('text-warm-900');
    t.classList.add('text-warm-500');
  });

  // Reset all arrows
  megaArrows.forEach((arrow) => {
    arrow.classList.remove('rotate-180');
  });

  // Hide container
  megaContainer?.classList.add('opacity-0', 'invisible', 'translate-y-4', 'pointer-events-none');
  megaContainer?.classList.remove('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
}

  // function closeMegaMenu() {
  //   activeMegaIndex = -1;
    
  //   megaTriggers.forEach(t => {
  //     t.setAttribute('aria-expanded', 'false');
  //     t.classList.remove('text-warm-900');
  //     t.classList.add('text-warm-500');
  //   });

  //   megaArrows.forEach(arrow => {
  //     arrow.classList.remove('rotate-180');
  //   });

  //   megaContainer?.classList.add('opacity-0', 'invisible', 'translate-y-4', 'pointer-events-none');
  //   megaContainer?.classList.remove('opacity-100', 'visible', 'translate-y-0', 'pointer-events-auto');
  // }

  document.addEventListener('click', (e) => {
    const target = e.target;
    const isInsideMega = megaContainer?.contains(target);
    const isTrigger = target.closest('.mega-trigger');
    
    if (!isInsideMega && !isTrigger) {
      closeMegaMenu();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeMegaMenu();
      if (isMobileOpen) toggleMobileMenu();
    }
  });

  menuBtn?.addEventListener('click', () => {
    toggleMobileMenu();
  });

  function toggleMobileMenu() {
    isMobileOpen = !isMobileOpen;
    menuBtn?.setAttribute('aria-expanded', String(isMobileOpen));
    
    if (isMobileOpen) {
      closeMegaMenu();
      mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu?.classList.add('opacity-100', 'pointer-events-auto');
      
      line1?.classList.add('rotate-45', 'translate-y-[5px]');
      line2?.classList.add('opacity-0', 'w-0');
      line3?.classList.add('-rotate-45', '-translate-y-[5px]', 'w-6');
      
      mobileLinks.forEach(link => {
        link.classList.remove('opacity-0', 'translate-y-4');
        link.classList.add('opacity-100', 'translate-y-0');
      });
    } else {
      mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto');
      
      line1?.classList.remove('rotate-45', 'translate-y-[5px]');
      line2?.classList.remove('opacity-0', 'w-0');
      line3?.classList.remove('-rotate-45', '-translate-y-[5px]', 'w-6');
      
      mobileLinks.forEach(link => {
        link.classList.add('opacity-0', 'translate-y-4');
        link.classList.remove('opacity-100', 'translate-y-0');
      });
    }
  }

  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (isMobileOpen) toggleMobileMenu();
    });
  });
</script>