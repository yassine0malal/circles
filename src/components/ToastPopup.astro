---
export interface Props {
  id?: string;
  title?: string;
  message?: string;
  buttonText?: string;
  autoShow?: boolean;
  delay?: number;
}

const {
  id = "toast-popup",
  title = "Congratulations!",
  message = "Your request has been approved.",
  buttonText = "Okay",
  autoShow = false,
  delay = 0,
} = Astro.props;
---

<style>
  .toast-backdrop {
    position: fixed;
    inset: 0;
    background-color: rgba(42, 33, 53, 0.45);
    backdrop-filter: blur(6px);
    z-index: 50;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .toast-backdrop.active {
    opacity: 1;
    visibility: visible;
  }

  .toast-card {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.96);
    width: 100%;
    max-width: 420px;
    background-color: var(--color-raised, #FFFDFB);
    border-radius: 20px;
    padding: 48px 32px 32px;
    text-align: center;
    box-shadow: 0 24px 64px rgba(42, 33, 53, 0.15), 0 0 0 1px rgba(42, 33, 53, 0.06);
    z-index: 51;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                visibility 0.35s;
  }

  .toast-card.active {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
  }

  .toast-icon {
    width: 72px;
    height: 72px;
    margin: 0 auto 24px;
    border-radius: 50%;
    background-color: var(--color-sage, #6E8B7A);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .toast-icon::before {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 2px solid var(--color-sage, #6E8B7A);
    opacity: 0.15;
    animation: toastPulse 2s ease-in-out infinite;
  }

  @keyframes toastPulse {
    0%, 100% { transform: scale(1); opacity: 0.15; }
    50% { transform: scale(1.08); opacity: 0.08; }
  }

  .toast-icon svg {
    width: 32px;
    height: 32px;
    color: white;
  }

  .toast-title {
    font-family: var(--font-display, "Fraunces", Georgia, serif);
    font-size: 22px;
    font-weight: 600;
    color: var(--color-ink, #2A2135);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .toast-message {
    font-family: var(--font-body, "Hanken Grotesk", system-ui, sans-serif);
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-ink-soft, #574B63);
    margin-bottom: 28px;
  }

  .toast-btn {
    display: block;
    width: 100%;
    padding: 14px 24px;
    border-radius: 12px;
    border: none;
    background-color: var(--color-sage, #6E8B7A);
    color: white;
    font-family: var(--font-body, "Hanken Grotesk", system-ui, sans-serif);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .toast-btn:hover {
    background-color: var(--color-sage-deep, #4F6B5B);
    transform: translateY(-1px);
  }

  .toast-btn:active {
    transform: scale(0.98);
  }

  .toast-confetti {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 80px;
    pointer-events: none;
    overflow: visible;
  }

  .confetti-piece {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    opacity: 0;
  }

  .toast-card.active .confetti-piece {
    animation: confettiFall 1.2s ease-out forwards;
  }

  .confetti-piece:nth-child(1) { background: var(--color-rose, #C16F72); left: 20%; top: 0; animation-delay: 0.1s; }
  .confetti-piece:nth-child(2) { background: var(--color-amber, #E0A35C); left: 40%; top: 10px; width: 6px; height: 6px; animation-delay: 0.2s; }
  .confetti-piece:nth-child(3) { background: var(--color-sage, #6E8B7A); left: 60%; top: 5px; width: 10px; height: 4px; border-radius: 4px; animation-delay: 0.15s; }
  .confetti-piece:nth-child(4) { background: var(--color-rose-ink, #A8504C); left: 75%; top: 15px; width: 5px; height: 5px; animation-delay: 0.3s; }
  .confetti-piece:nth-child(5) { background: var(--color-amber, #E0A35C); left: 30%; top: 20px; width: 7px; height: 7px; border-radius: 50%; animation-delay: 0.25s; }
  .confetti-piece:nth-child(6) { background: var(--color-sage-deep, #4F6B5B); left: 50%; top: 0; width: 6px; height: 10px; animation-delay: 0.35s; }
  .confetti-piece:nth-child(7) { background: var(--color-rose, #C16F72); left: 85%; top: 8px; width: 8px; height: 5px; border-radius: 4px; animation-delay: 0.2s; }
  .confetti-piece:nth-child(8) { background: var(--color-amber, #E0A35C); left: 10%; top: 12px; width: 5px; height: 5px; border-radius: 50%; animation-delay: 0.4s; }

  @keyframes confettiFall {
    0% {
      opacity: 1;
      transform: translateY(0) rotate(0deg) scale(1);
    }
    100% {
      opacity: 0;
      transform: translateY(60px) rotate(720deg) scale(0.3);
    }
  }
</style>

<!-- Toast Popup -->
<div id={`${id}-backdrop`} class="toast-backdrop"></div>

<div id={id} class="toast-card">
  <div class="toast-confetti">
    <div class="confetti-piece"></div>
    <div class="confetti-piece"></div>
    <div class="confetti-piece"></div>
    <div class="confetti-piece"></div>
    <div class="confetti-piece"></div>
    <div class="confetti-piece"></div>
    <div class="confetti-piece"></div>
    <div class="confetti-piece"></div>
  </div>

  <div class="toast-icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
  </div>

  <h3 class="toast-title">{title}</h3>
  <p class="toast-message">{message}</p>

  <button type="button" class="toast-btn" data-toast-close={id}>
    {buttonText}
  </button>
</div>

<script is:inline define:vars={{ id, autoShow, delay }}>
  (function() {
    const backdrop = document.getElementById(id + '-backdrop');
    const card = document.getElementById(id);
    const closeBtn = document.querySelector('[data-toast-close="' + id + '"]');

    function show() {
      backdrop.classList.add('active');
      card.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function hide() {
      backdrop.classList.remove('active');
      card.classList.remove('active');
      document.body.style.overflow = '';
    }

    window['show' + id.replace(/-/g, '_')] = show;
    window['hide' + id.replace(/-/g, '_')] = hide;

    closeBtn.addEventListener('click', hide);
    backdrop.addEventListener('click', hide);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') hide();
    });

    if (autoShow) {
      setTimeout(show, delay);
    }
  })();
</script>