<section class="py-24 px-8 max-w-4xl mx-auto text-center">
  <p class="text-xs font-light tracking-[0.3em] uppercase text-warm-500 mb-6">Stay connected</p>
  <h2 class="font-serif text-4xl md:text-5xl font-medium text-warm-900 leading-tight mb-6">
    Subscribe to our<br /><span class="italic">newsletter</span>
  </h2>
  <p class="text-base font-light text-warm-500 mb-12 max-w-md mx-auto">
    Receive reflections, circle openings, and insights for a healthier mind.
  </p>

  <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto" onsubmit="event.preventDefault();">
    <input 
      type="email" 
      placeholder="your@email.com" 
      class="flex-1 bg-transparent border border-warm-300 rounded-full px-8 py-4 text-sm font-light text-warm-900 placeholder:text-warm-400 focus:outline-none focus:border-warm-800 transition-colors duration-300"
    />
    <button type="submit" class="px-10 py-4 bg-warm-800 text-cream text-sm font-light tracking-wide rounded-full hover:bg-olive transition-colors duration-500">
      Subscribe
    </button>
  </form>
  <p class="text-xs font-light text-warm-400 mt-6">By subscribing you agree to our privacy policy</p>
</section>