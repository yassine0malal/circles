---
export interface Props {
  id: string;
  label: string;
}

const { id, label } = Astro.props;
---

<label class="flex items-center gap-3 cursor-pointer group">
  <div class="relative shrink-0">
    <input type="checkbox" id={id} class="peer sr-only" />
    <div class="w-5 h-5 rounded border border-line bg-white peer-checked:bg-rose peer-checked:border-rose transition-all flex items-center justify-center">
      <svg class="w-3 h-3 text-cream opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
  </div>
  <span class="text-sm text-ink-soft group-hover:text-ink transition-colors leading-tight">{label}</span>
</label>