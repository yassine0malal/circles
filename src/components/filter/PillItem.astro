---
export interface Props {
  label: string;
}

const { label } = Astro.props;
---

<label class="cursor-pointer">
  <input type="checkbox" class="peer sr-only" />
  <span class="inline-block px-4 py-2 rounded-full border border-line text-sm text-ink-soft bg-white peer-checked:bg-rose peer-checked:text-cream peer-checked:border-rose hover:border-rose transition-all duration-200">
    {label}
  </span>
</label>