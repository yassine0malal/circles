---
export interface Props {
  therapist: {
    name: string;
    image: string;
    credentials: string;
    verified?: boolean;
    endorsed?: number;
    location: string;
    phone: string;
    bio: string;
  };
}

const { therapist } = Astro.props;
const slug = therapist.name.toLowerCase().replace(/\s+/g, "-");
---

<article class="relative bg-white rounded-2xl border border-line p-6 lg:p-8 hover:shadow-lg hover:shadow-ink/10 transition-all duration-500 group cursor-pointer">
  {/* Invisible full-card link */}
  <a
    href={`/companions/${slug}`}
    class="absolute inset-0 z-0 rounded-2xl"
    aria-label={`View ${therapist.name}'s profile`}
  />

  <div class="relative z-10 flex flex-col lg:flex-row gap-6 pointer-events-none">
    {/* Photo */}
    <div class="shrink-0 pointer-events-auto">
      <div class="w-24 h-24 lg:w-32 lg:h-32 rounded-xl overflow-hidden bg-raised">
        <img
          src={therapist.image}
          alt={therapist.name}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>

    {/* Info */}
    <div class="flex-1 min-w-0">
      <div class="flex items-start justify-between gap-4 mb-1">
        <div>
          <h3 class="text-2xl font-medium text-ink group-hover:text-sage transition-colors">
            {therapist.name}
          </h3>

          <div class="flex items-center gap-2 mt-1 flex-wrap">
            <span class="text-sm text-ink-soft/90">
              {therapist.credentials}
            </span>
            {therapist.verified && (
              <span class="inline-flex items-center gap-1 text-xs text-sage font-bold">
                <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 003.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  />
                </svg>
                Verified
              </span>
            )}
            {therapist.endorsed && therapist.endorsed > 0 && (
              <span class="text-xs text-ink-soft/70">
                · {therapist.endorsed} Endorsed
              </span>
            )}
          </div>
          <p class="text-xs text-ink-soft/50 mt-1">{therapist.location}</p>
        </div>

        {/* Desktop: Phone + Actions */}
        <div class="hidden lg:flex flex-col items-end gap-2 shrink-0">
          <a
            href={`tel:${therapist.phone}`}
            class="relative z-20 text-lg font-medium text-ink hover:text-sage transition-colors pointer-events-auto"
          >
            {therapist.phone}
          </a>
          <div class="flex items-center gap-2">
            <a
              href="#"
              class="relative z-20 px-4 py-2 border border-line rounded-full text-sm text-ink-soft/90 hover:border-line hover:text-ink transition-all bg-white pointer-events-auto"
            >
              Email
            </a>
            <a
              href={`/companions/${slug}`}
              class="relative z-20 px-4 py-2 bg-[linear-gradient(160deg,#241B2E_0%,#2A2135_50%,#574B63_100%)] text-cream rounded-full text-sm font-medium hover:bg-sage transition-colors pointer-events-auto"
            >
              View
            </a>
          </div>
        </div>
      </div>

      <p class="text-sm font-normal text-ink-soft/90 leading-relaxed mt-3 line-clamp-3">
        {therapist.bio}
      </p>

      {/* Mobile Actions */}
      <div class="flex lg:hidden items-center gap-3 mt-4">
        <a
          href={`tel:${therapist.phone}`}
          class="relative z-20 text-sm font-medium text-ink pointer-events-auto"
        >
          {therapist.phone}
        </a>
        <a
          href="#"
          class="relative z-20 px-4 py-2 border border-line rounded-full text-sm text-ink-soft/90 bg-white pointer-events-auto"
        >
          Email
        </a>
        <a
          href={`/companions/${slug}`}
          class="relative z-20 px-4 py-2 bg-ink text-cream rounded-full text-sm pointer-events-auto"
        >
          View
        </a>
      </div>
    </div>
  </div>
</article>