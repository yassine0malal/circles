---
interface Therapist {
  name: string;
  credentials: string;
  location: string;
  phone: string;
  lat: number;
  lng: number;
  image: string;
}

interface Props {
  therapists: Therapist[];
}

const { therapists } = Astro.props;
---

<div
  id="therapist-map"
  class="w-full h-[420px] rounded-2xl border border-line overflow-hidden mb-10 relative z-0"
  data-therapists={JSON.stringify(therapists)}
>
  <div
    class="absolute top-4 left-4 z-10 bg-white/90 backdrop-blur-sm px-4 py-2 rounded-full border border-line shadow-sm"
  >
    <p class="text-xs font-medium text-ink-soft">
      <span class="text-sage font-bold">{therapists.length}</span> therapists near
      you
    </p>
  </div>
</div>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<script>
  import L from "leaflet";

  // Redeclare interface inside <script> so TypeScript knows the shape
  interface Therapist {
    name: string;
    credentials: string;
    location: string;
    phone: string;
    lat: number;
    lng: number;
    image: string;
  }

  (function initMap() {
    const mapEl = document.getElementById("therapist-map");
    if (!mapEl) return;

    // Cast parsed JSON so therapists is typed
    const therapists = JSON.parse(
      mapEl.dataset.therapists || "[]",
    ) as Therapist[];

    const map = L.map("therapist-map", {
      zoomControl: false,
      scrollWheelZoom: false,
    }).setView([40.6782, -73.9442], 12);

    L.control.zoom({ position: "bottomright" }).addTo(map);

    L.tileLayer(
      "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
      {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: "abcd",
        maxZoom: 19,
      },
    ).addTo(map);

    const createCustomIcon = () => {
      return L.divIcon({
        className: "custom-marker",
        html: `
          <div style="
            width: 36px; 
            height: 36px; 
            background: #5c6b4a; 
            border-radius: 50%; 
            border: 3px solid #faf9f6; 
            box-shadow: 0 4px 12px rgba(44,42,38,0.25); 
            display: flex; 
            align-items: center; 
            justify-content: center;
            transition: transform 0.2s ease;
          ">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#faf9f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
        `,
        iconSize: [36, 36],
        iconAnchor: [18, 36],
        popupAnchor: [0, -36],
      });
    };

    // Explicitly type bounds as LatLngExpression array
    const bounds = L.latLngBounds([]);

    therapists.forEach((t: Therapist) => {
      const marker = L.marker([t.lat, t.lng], {
        icon: createCustomIcon(),
      }).addTo(map);

      marker.bindPopup(
        `
        <div style="font-family: 'DM Sans', system-ui, sans-serif; min-width: 240px; padding: 4px;">
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
            <img src="${t.image}" alt="${t.name}" style="width: 48px; height: 48px; border-radius: 10px; object-fit: cover; border: 2px solid #e8e2d9;">
            <div>
              <h3 style="margin: 0; font-size: 15px; font-weight: 600; color: #1a1714; font-family: 'Playfair Display', serif;">${t.name}</h3>
              <p style="margin: 2px 0 0; font-size: 12px; color: #6b5f4f;">${t.credentials}</p>
            </div>
          </div>
          <p style="margin: 0 0 8px; font-size: 12px; color: #8a7d6b;">${t.location}</p>
          <a href="tel:${t.phone}" style="
            display: inline-flex; 
            align-items: center; 
            gap: 6px;
            padding: 8px 16px; 
            background: #2d2822; 
            color: #f5f1eb; 
            text-decoration: none; 
            border-radius: 20px; 
            font-size: 12px; 
            font-weight: 500;
            transition: background 0.3s;
          ">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            ${t.phone}
          </a>
        </div>
      `,
        {
          closeButton: false,
          className: "custom-popup",
        },
      );

      bounds.extend([t.lat, t.lng]);
    });

    // The fitBounds call stays the same:
    if (bounds.isValid()) {
      map.fitBounds(bounds, {
        padding: [60, 60],
        maxZoom: 14,
      });
    }

    const style = document.createElement("style");
    style.textContent = `
      .custom-marker:hover > div {
        transform: scale(1.15) !important;
      }
      .leaflet-popup-content-wrapper {
        border-radius: 16px !important;
        box-shadow: 0 8px 32px rgba(44,42,38,0.15) !important;
        border: 1px solid #e8e2d9 !important;
        padding: 4px !important;
      }
      .leaflet-popup-tip {
        background: white !important;
        border: 1px solid #e8e2d9 !important;
        box-shadow: none !important;
      }
    `;
    document.head.appendChild(style);
  })();
</script>
