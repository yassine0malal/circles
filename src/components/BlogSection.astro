---
const posts = [
  { title: "The connection between physical and mental health", category: "Articles", date: "Dec 10, 2024", image: "https://images.unsplash.com/photo-1544027993-37dbfe43562a?w=400&h=250&fit=crop" },
  { title: "Understanding the impact of stress on mental health", category: "News", date: "Dec 31, 2024", image: "https://images.unsplash.com/photo-1516307073036-4d4205e2f6d2?w=400&h=250&fit=crop" },
  { title: "The power of mindfulness in daily life", category: "Articles", date: "Dec 12, 2024", image: "https://images.unsplash.com/photo-1516589178581-6cd7833ae3b2?w=400&h=250&fit=crop" },
];
---

<section class="px-6 py-20 max-w-6xl mx-auto text-center">
  <p class="text-xs text-gray-500 uppercase tracking-wider mb-2">Blog & resources</p>
  <h2 class="text-3xl font-medium text-gray-900 mb-4">
    Insights and tips for a<br />healthier mind
  </h2>
  <a href="/blog" class="inline-block px-6 py-2 bg-teal-700 text-white text-sm font-medium rounded-full hover:bg-teal-800 transition mb-12">
    Explore All
  </a>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
    {posts.map(post => (
      <article class="group cursor-pointer">
        <div class="rounded-xl overflow-hidden mb-4">
          <img 
            src={post.image} 
            alt={post.title}
            class="w-full h-48 object-cover group-hover:scale-105 transition duration-300"
            onerror="this.src='https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=400&h=250&fit=crop'"
          />
        </div>
        <h3 class="font-semibold text-gray-900 text-sm mb-2 group-hover:text-teal-700 transition">{post.title}</h3>
        <div class="flex items-center gap-2 text-xs text-gray-500">
          <span>{post.category}</span>
          <span>•</span>
          <span>{post.date}</span>
        </div>
      </article>
    ))}
  </div>
</section>