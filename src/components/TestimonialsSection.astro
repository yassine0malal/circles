---
const testimonials = [
  { name: "Sophia Bennett", role: "Creative Director", text: "Circle Share helped me rediscover balance in my life. The sessions were insightful and tailored to my needs. I feel more confident and in control of my emotions now." },
  { name: "Muzammil Hussain", role: "Product Designer", text: "The supportive environment in a group therapy made all the difference. Their personalized approach helped me overcome challenges I had been struggling with for years." },
  { name: "Ethan Carter", role: "Marketing Lead", text: "Thanks to Circle Share, I've developed effective tools to manage stress and improve my overall well-being. It's been a transformative experience for my mental health." },
];
---

<section class="py-28 px-8 bg-warm-100">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <p class="text-xs font-light tracking-[0.3em] uppercase text-warm-500 mb-4">Testimonials</p>
      <h2 class=" text-4xl md:text-5xl font-medium text-warm-900 leading-tight">
        Hear from our <span class="italic">seekers</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map(t => (
        <div class="bg-cream rounded-2xl p-10 hover:shadow-xl hover:shadow-warm-200/50 transition-all duration-500">
          <div class="flex gap-1 mb-8">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-olive fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-base font-light text-warm-700 leading-[1.8] mb-10 italic">"{t.text}"</p>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-warm-300 flex items-center justify-center  text-warm-700 text-lg">
              {t.name.charAt(0)}
            </div>
            <div>
              <p class="text-sm font-medium text-warm-900">{t.name}</p>
              <p class="text-xs font-light text-warm-500">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>