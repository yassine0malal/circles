---
const circles = [
  { title: 'Identity & Belonging', desc: 'Explore who you are and find your place in community', rating: '4.8', image: 'https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=500&h=600&fit=crop&q=80' },
  { title: 'Life Transition', desc: 'Navigate change with support and clarity', rating: '4.9', image: 'https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=500&h=600&fit=crop&q=80' },
  { title: 'Caregiving & Support', desc: 'For those who give — a space to receive', rating: '4.9', image: 'https://images.unsplash.com/photo-1516307073036-4d4205e2f6d2?w=500&h=600&fit=crop&q=80' },
  { title: 'Burnout & Boundaries', desc: 'Reclaim your energy and learn to protect it', rating: '4.7', image: 'https://images.unsplash.com/photo-1544027993-37dbfe43562a?w=500&h=600&fit=crop&q=80' },
  { title: 'Loneliness & Connection', desc: 'Turn isolation into meaningful bonds', rating: '4.5', image: 'https://images.unsplash.com/photo-1516589178581-6cd7833ae3b2?w=500&h=600&fit=crop&q=80' },
  { title: 'Grief & Regrowth', desc: 'Honor loss while gently moving forward', rating: '4.9', image: 'https://images.unsplash.com/photo-1516307073036-4d4205e2f6d2?w=500&h=600&fit=crop&q=80' },
];
---

<section class="py-28 px-8 max-w-7xl mx-auto">
  <div class="text-center mb-20">
    <p class="text-xs font-light tracking-[0.3em] uppercase text-warm-500 mb-4">Circles you can join</p>
    <h2 class="text-4xl md:text-5xl font-medium text-warm-900 leading-tight">
      Find a circle that fits<br />your <span class="italic">moment</span>
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-14">
    {circles.map((circle, i) => (
      <article class="group cursor-pointer">
        <div class="relative aspect-[4/5] rounded-xl overflow-hidden mb-6 bg-warm-200">
          <img 
            src={circle.image} 
            alt={circle.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
            onerror="this.src='https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=500&h=600&fit=crop'"
          />
          <div class="absolute top-4 right-4 bg-cream/90 backdrop-blur-sm px-3 py-1.5 rounded-full">
            <span class="flex items-center gap-1 text-xs font-medium text-warm-800">
              <svg class="w-3 h-3 text-olive fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              {circle.rating}
            </span>
          </div>
        </div>
        <h3 class=" text-xl font-medium text-warm-900 mb-2 group-hover:text-olive transition-colors duration-300">{circle.title}</h3>
        <p class="text-sm font-light text-warm-500 leading-relaxed">{circle.desc}</p>
      </article>
    ))}
  </div>

  <div class="text-center mt-20">
    <a href="/circles" class="inline-flex items-center gap-3 text-sm font-light tracking-wide text-warm-800 border-b border-warm-800 pb-1 hover:text-olive hover:border-olive transition-all duration-500">
      View all circles
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </div>
</section>