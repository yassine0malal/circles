<script>
  // Safely grab elements and cast them to their proper DOM types
  const dropdown = document.getElementById(
    "state-dropdown",
  ) as HTMLDivElement | null;
  const trigger = document.getElementById(
    "state-trigger",
  ) as HTMLButtonElement | null;
  const menu = document.getElementById("state-menu") as HTMLDivElement | null;
  const arrow = document.getElementById("state-arrow") as HTMLElement | null;
  const selectedText = document.getElementById(
    "selected-state-text",
  ) as HTMLSpanElement | null;
  const options = document.querySelectorAll<HTMLButtonElement>(".state-option");

  // Grab the span inside your "See all" button
  const seeAllStateText = document.getElementById(
    "see-all-state",
  ) as HTMLSpanElement | null;

  let isOpen: boolean = false;

  // Toggle dropdown open/close
  function toggleDropdown(): void {
    // Guard clause to satisfy TypeScript null-checking
    if (!trigger || !menu || !arrow) return;

    isOpen = !isOpen;
    trigger.setAttribute("aria-expanded", String(isOpen));

    if (isOpen) {
      // Open state classes
      menu.classList.remove("opacity-0", "invisible", "translate-y-[-10px]");
      menu.classList.add("opacity-100", "visible", "translate-y-0");
      arrow.classList.add("-rotate-180");
      trigger.classList.add("border-sage", "ring-2", "ring-sage/20");
    } else {
      // Close state classes
      menu.classList.add("opacity-0", "invisible", "translate-y-[-10px]");
      menu.classList.remove("opacity-100", "visible", "translate-y-0");
      arrow.classList.remove("-rotate-180");
      trigger.classList.remove("border-sage", "ring-2", "ring-sage/20");
    }
  }

  // Handle trigger click
  trigger?.addEventListener("click", (e: MouseEvent) => {
    e.stopPropagation(); // Prevent immediate closing from the document click listener
    toggleDropdown();
  });

  // Handle option selection
  options.forEach((option: HTMLButtonElement) => {
    option.addEventListener("click", (e: MouseEvent) => {
      e.stopPropagation();

      // Explicitly cast currentTarget so TS knows it has a dataset property
      const target = e.currentTarget as HTMLButtonElement;
      const newState: string = target.dataset.value || target.textContent || "";

      // Update the text in the dropdown button
      if (selectedText) {
        selectedText.textContent = newState;
      }

      // Update the text in the "See all" link at the bottom of the section
      if (seeAllStateText) {
        seeAllStateText.textContent = newState;
      }

      // Close the menu
      toggleDropdown();
    });
  });

  // Close dropdown when clicking anywhere outside of it
  document.addEventListener("click", (e: MouseEvent) => {
    // Cast the event target to a Node so the .contains() method is recognized
    const target = e.target as Node;

    if (isOpen && dropdown && !dropdown.contains(target)) {
      toggleDropdown();
    }
  });
</script>

