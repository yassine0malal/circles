---
const stages = [
  {
    id: 1,
    title: "What do I need?",
    subtitle: "Primary Need",
    description:
      "Choose the pathways and specific needs that resonate with you.",
    sections: [
      {
        header: "Deep Relational & Personal Growth",
        options: ["Heal", "Belong", "Grow", "Create"],
      },
      {
        header: "Tools, Skills & Support for Daily Life",
        options: ["Learn", "Support", "Restore"],
      },
    ],
  },
  {
    id: 2,
    title: "What kind of experience am I looking for?",
    subtitle: "Therapeutic Approach",
    description:
      "Select all the engagement styles and formats that feel right for you.",
    options: [
      "Process Group",
      "Psychoeducational Group",
      "Support Group",
      "Consultation Group",
      "Workshop Series",
      "Retreat",
      "Open Circle",
      "Closed Circle",
      "Drop-In",
    ],
  },
  {
    id: 3,
    title: "Who feels like the right guide?",
    subtitle: "Companion Profile",
    description:
      "What qualities do you want in your facilitator? Choose as many as you like.",
    options: [
      "Warm & Empathetic",
      "Direct & Honest",
      "Structured & Goal-Oriented",
      "Creative & Intuitive",
      "Spiritually-Grounded",
      "Trauma-Informed",
      "Playful & Light",
      "Wise & Experienced",
    ],
  },
];
---

<style>
  @import url("https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Hanken+Grotesk:wght@300..900&display=swap");

  :root {
    --color-ink: #2a2135;
    --color-ink-2: #241b2e;
    --color-ink-soft: #574b63;
    --color-canvas: #f8f2ee;
    --color-raised: #fffdfb;
    --color-rose: #c16f72;
    --color-rose-ink: #a8504c;
    --color-amber: #e0a35c;
    --color-sage: #6e8b7a;
    --color-sage-deep: #4f6b5b;
    --color-mist: #ebe0d8;
    --color-cream: #f6ece3;
    --color-line: rgba(42, 33, 53, 0.1);
    --font-display: "Fraunces", Georgia, serif;
    --font-body: "Hanken Grotesk", system-ui, sans-serif;
  }

  .pf-font-display {
    font-family: var(--font-display);
  }
  .pf-font-body {
    font-family: var(--font-body);
  }

  .pf-scroll::-webkit-scrollbar {
    width: 6px;
  }
  .pf-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .pf-scroll::-webkit-scrollbar-thumb {
    background-color: var(--color-mist);
    border-radius: 20px;
  }

  .pf-fade-in {
    animation: pfFadeIn 0.3s ease-out forwards;
  }
  .pf-scale-in {
    animation: pfScaleIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes pfFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes pfScaleIn {
    from {
      opacity: 0;
      transform: scale(0.96) translateY(10px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  .pf-stage {
    display: none;
    opacity: 0;
    transform: translateY(15px);
    transition:
      opacity 0.4s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .pf-stage.active {
    display: block;
  }
  .pf-stage.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .pf-stagger-item {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.4s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .pf-stage.visible .pf-stagger-item {
    opacity: 1;
    transform: translateY(0);
  }

  .pf-stagger-item:nth-child(1) {
    transition-delay: 0.05s;
  }
  .pf-stagger-item:nth-child(2) {
    transition-delay: 0.1s;
  }
  .pf-stagger-item:nth-child(3) {
    transition-delay: 0.15s;
  }
  .pf-stagger-item:nth-child(4) {
    transition-delay: 0.2s;
  }
  .pf-stagger-item:nth-child(5) {
    transition-delay: 0.25s;
  }
  .pf-stagger-item:nth-child(6) {
    transition-delay: 0.3s;
  }
  .pf-stagger-item:nth-child(7) {
    transition-delay: 0.35s;
  }

  .pf-option-card {
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .pf-option-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(42, 33, 53, 0.06);
  }
  .pf-option-card:active {
    transform: translateY(1px) scale(0.98);
  }
  .pf-option-card.selected {
    border-color: var(--color-sage);
    background-color: rgba(110, 139, 122, 0.06);
    box-shadow: 0 0 0 1px var(--color-sage);
  }

  .pf-umbrella-toggle {
    transition: all 0.2s ease;
  }
  .pf-umbrella-toggle:hover {
    background-color: var(--color-cream);
  }
  .pf-umbrella-toggle:active {
    transform: scale(0.99);
  }
  .pf-umbrella-toggle.active {
    background-color: rgba(110, 139, 122, 0.08);
  }

  #pf-progress-bar {
    box-shadow: 0 0 8px rgba(110, 139, 122, 0.4);
  }

  .pf-step-line {
    position: absolute;
    left: 19px;
    top: 36px;
    bottom: -8px;
    width: 2px;
    background: repeating-linear-gradient(
      to bottom,
      var(--color-line) 0,
      var(--color-line) 4px,
      transparent 4px,
      transparent 8px
    );
  }
  .pf-step-item:last-child .pf-step-line {
    display: none;
  }
</style>

<div
  id="pf-modal"
  class="fixed inset-0 z-50"
  role="dialog"
  aria-modal="true"
  aria-labelledby="pf-modal-title"
>
  <div
    id="pf-backdrop"
    class="absolute inset-0 pf-fade-in"
    style="background-color: rgba(42, 33, 53, 0.45); backdrop-filter: blur(6px);"
  >
  </div>

  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div
      id="pf-card"
      class="pf-scale-in relative w-full max-w-5xl overflow-hidden rounded-2xl shadow-2xl flex flex-col md:flex-row"
      style="background-color: var(--color-raised); min-height: 580px; max-height: 90vh;"
    >
      <button
        type="button"
        id="pf-close"
        class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110 active:scale-95"
        style="background-color: var(--color-raised); border: 1px solid var(--color-mist); color: var(--color-ink-soft);"
        aria-label="Close"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
        >
      </button>

      <aside
        class="w-full md:w-[340px] flex flex-col border-b md:border-b-0 md:border-r p-6 md:p-8 shrink-0"
        style="background-color: var(--color-canvas); border-color: var(--color-line);"
      >
        <div class="mb-4">
          <h2
            class="pf-font-display text-2xl font-semibold"
            style="color: var(--color-ink);"
          >
            Find Your Path
          </h2>
        </div>

        <nav class="flex-1 relative mt-2">
          {
            stages.map((stage) => (
              <div
                class="pf-step-item relative pl-12 pb-6 cursor-pointer group"
                data-step={stage.id}
                data-step-nav
              >
                <div class="pf-step-line" />

                <div
                  class="pf-step-indicator absolute left-0 top-0 w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 z-10"
                  data-indicator={stage.id}
                  style="border: 2px solid var(--color-mist); color: var(--color-ink-soft); background: var(--color-raised);"
                >
                  <span
                    class="pf-step-number text-sm font-semibold transition-all duration-300"
                    data-number={stage.id}
                  >
                    {stage.id}
                  </span>
                  <svg
                    class="pf-step-check hidden w-5 h-5 text-white transition-all duration-300"
                    data-check={stage.id}
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                </div>

                <div
                  class="pf-step-content -mt-1 transition-all duration-300 p-3.5 -ml-2"
                  data-content={stage.id}
                >
                  <div
                    class="text-[10px] font-bold uppercase tracking-wider mb-1.5 opacity-80"
                    style="color: var(--color-sage-deep);"
                  >
                    Step {stage.id} • {stage.subtitle}
                  </div>
                  <h3
                    class="pf-font-display text-[17px] font-semibold leading-tight mb-1.5"
                    style="color: var(--color-ink);"
                  >
                    {stage.title}
                  </h3>
                  <p
                    class="text-xs leading-relaxed"
                    style="color: var(--color-ink-soft);"
                  >
                    {stage.description}
                  </p>
                </div>
              </div>
            ))
          }
        </nav>

        <div class="mt-auto pt-4 hidden md:block">
          <div
            class="flex items-center justify-between text-xs mb-2"
            style="color: var(--color-ink-soft);"
          >
            <span>Progress</span>
            <span id="pf-progress-text">1 / 3</span>
          </div>
          <div
            class="h-1.5 w-full rounded-full overflow-hidden"
            style="background-color: var(--color-mist);"
          >
            <div
              id="pf-progress-bar"
              class="h-full rounded-full transition-all duration-500 ease-out"
              style="background-color: var(--color-sage); width: 33%;"
            >
            </div>
          </div>
        </div>
      </aside>

      <main
        class="flex-1 flex flex-col overflow-hidden"
        style="background-color: var(--color-raised);"
      >
        <div
          class="flex-1 overflow-y-auto pf-scroll p-6 md:p-10 pt-14 md:pt-10"
        >
          {
            stages.map((stage) => (
              <div class="pf-stage" data-stage={stage.id}>
                <div class="space-y-8">
                  {"sections" in stage ? (
                    stage.sections.map((section) => (
                      <div class="pf-stagger-item">
                        <button
                          type="button"
                          class="pf-umbrella-toggle pf-font-body w-full text-left rounded-xl border px-4 py-3 mb-3 flex items-center justify-between group"
                          style="border-color: var(--color-line); color: var(--color-ink);"
                          data-umbrella={section.header}
                          data-stage-id={stage.id}
                        >
                          <span class="font-semibold text-sm md:text-base">
                            {section.header}
                          </span>
                          <div
                            class="pf-umbrella-dot w-5 h-5 rounded border-2 flex items-center justify-center transition-all"
                            style="border-color: var(--color-mist);"
                          >
                            <svg
                              class="w-3.5 h-3.5 opacity-0 transition-all"
                              style="color: var(--color-sage);"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="3"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <polyline points="20 6 9 17 4 12" />
                            </svg>
                          </div>
                        </button>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pl-2">
                          {section.options.map((opt) => (
                            <button
                              type="button"
                              class="pf-option-card pf-font-body text-left rounded-xl border p-4 md:p-5 relative group"
                              style="border-color: var(--color-line); background-color: var(--color-raised); color: var(--color-ink);"
                              data-option={opt}
                              data-parent={section.header}
                              data-stage-id={stage.id}
                            >
                              <div class="flex items-center justify-between">
                                <span class="font-medium text-sm md:text-base">
                                  {opt}
                                </span>
                                <div
                                  class="pf-option-dot w-5 h-5 rounded border-2 flex items-center justify-center transition-all"
                                  style="border-color: var(--color-mist);"
                                >
                                  <svg
                                    class="w-3 h-3 opacity-0 transition-all"
                                    style="color: var(--color-sage);"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="3"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                  >
                                    <polyline points="20 6 9 17 4 12" />
                                  </svg>
                                </div>
                              </div>
                            </button>
                          ))}
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                      {stage.options.map((opt) => (
                        <button
                          type="button"
                          class="pf-stagger-item pf-option-card pf-font-body text-left rounded-xl border p-4 md:p-5 relative group"
                          style="border-color: var(--color-line); background-color: var(--color-raised); color: var(--color-ink);"
                          data-option={opt}
                          data-stage-id={stage.id}
                        >
                          <div class="flex items-center justify-between">
                            <span class="font-medium text-sm md:text-base">
                              {opt}
                            </span>
                            <div
                              class="pf-option-dot w-5 h-5 rounded border-2 flex items-center justify-center transition-all"
                              style="border-color: var(--color-mist);"
                            >
                              <svg
                                class="w-3 h-3 opacity-0 transition-all"
                                style="color: var(--color-sage);"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="3"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <polyline points="20 6 9 17 4 12" />
                              </svg>
                            </div>
                          </div>
                        </button>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))
          }
        </div>

        <div
          class="flex items-center justify-between p-6 md:px-10 md:py-6 border-t"
          style="border-color: var(--color-line); background-color: var(--color-raised);"
        >
          <button
            type="button"
            id="pf-btn-back"
            class="pf-font-body inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-medium transition-all active:scale-95 disabled:opacity-30 disabled:cursor-not-allowed hover:bg-black/5"
            style="color: var(--color-ink);"
            disabled
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
            >
            Back
          </button>
          <button
            type="button"
            id="pf-btn-next"
            class="pf-font-body inline-flex items-center gap-2 rounded-xl px-6 py-2.5 text-sm font-semibold text-white transition-all hover:opacity-90 active:scale-95 disabled:opacity-40 disabled:cursor-not-allowed"
            style="background-color: var(--color-ink);"
            disabled
          >
            <span id="pf-btn-next-text">Continue</span>
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
            >
          </button>
        </div>
      </main>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const modal = document.getElementById("pf-modal");
    const backdrop = document.getElementById("pf-backdrop");
    const closeBtn = document.getElementById("pf-close");
    const btnBack = document.getElementById("pf-btn-back");
    const btnNext = document.getElementById("pf-btn-next");
    const btnNextText = document.getElementById("pf-btn-next-text");
    const progressBar = document.getElementById("pf-progress-bar");
    const progressText = document.getElementById("pf-progress-text");

    let currentStage = 1;
    const totalStages = 3;
    const selections = { 1: [], 2: [], 3: [] };

    const stageSections = {
      1: [
        {
          header: "Deep Relational & Personal Growth",
          options: ["Heal", "Belong", "Grow", "Create"],
        },
        {
          header: "Tools, Skills & Support for Daily Life",
          options: ["Learn", "Support", "Restore"],
        },
      ],
    };

    function closeModal() {
      modal.style.display = "none";
      document.body.style.overflow = "";
    }

    function isStageComplete(stageId) {
      return selections[stageId].length > 0;
    }

    function updateSidebar() {
      for (let i = 1; i <= totalStages; i++) {
        const indicator = document.querySelector(
          '[data-indicator="' + i + '"]',
        );
        const number = document.querySelector('[data-number="' + i + '"]');
        const check = document.querySelector('[data-check="' + i + '"]');
        const content = document.querySelector('[data-content="' + i + '"]');

        indicator.style.cssText =
          "border: 2px solid var(--color-mist); color: var(--color-ink-soft); background: var(--color-raised);";
        number.classList.remove("hidden");
        check.classList.add("hidden");

        content.style.background = "transparent";
        content.style.borderRadius = "12px";
        content.style.boxShadow = "none";

        if (i === currentStage) {
          indicator.style.background = "var(--color-sage)";
          indicator.style.borderColor = "var(--color-sage)";
          indicator.style.color = "#fff";

          content.style.background = "var(--color-cream)";
          content.style.borderTopLeftRadius = "4px";
          content.style.borderTopRightRadius = "20px";
          content.style.borderBottomRightRadius = "20px";
          content.style.borderBottomLeftRadius = "20px";
          content.style.boxShadow = "0 4px 12px rgba(42, 33, 53, 0.04)";
          content.style.opacity = "1";
        } else {
          content.style.opacity = "0.4";
        }

        if (i < currentStage) {
          indicator.style.background = "var(--color-ink)";
          indicator.style.borderColor = "var(--color-ink)";
          indicator.style.color = "#fff";
          number.classList.add("hidden");
          check.classList.remove("hidden");
        }
      }

      const pct = (currentStage / totalStages) * 100;
      progressBar.style.width = pct + "%";
      progressText.textContent =
        Math.min(currentStage, totalStages) + " / " + totalStages;
    }

    function getUmbrellaState(header, stageId) {
      const section = stageSections[stageId].find((s) => s.header === header);
      if (!section) return "empty";
      const selected = section.options.filter((o) =>
        selections[stageId].includes(o),
      );
      if (selected.length === 0) return "empty";
      if (selected.length === section.options.length) return "full";
      return "partial";
    }

    function toggleUmbrella(header, stageId) {
      const section = stageSections[stageId].find((s) => s.header === header);
      if (!section) return;
      const state = getUmbrellaState(header, stageId);
      if (state === "full") {
        selections[stageId] = selections[stageId].filter(
          (o) => !section.options.includes(o),
        );
      } else {
        section.options.forEach((o) => {
          if (!selections[stageId].includes(o)) selections[stageId].push(o);
        });
      }
    }

    function updateUmbrellaVisuals() {
      if (currentStage !== 1) return;
      stageSections[1].forEach((section) => {
        const btn = document.querySelector(
          '[data-umbrella="' + section.header + '"]',
        );
        if (!btn) return;
        const dot = btn.querySelector(".pf-umbrella-dot");
        const check = btn.querySelector(".pf-umbrella-dot svg");
        const state = getUmbrellaState(section.header, 1);

        if (state === "full") {
          btn.classList.add("active");
          dot.style.borderColor = "var(--color-sage)";
          dot.style.background = "var(--color-sage)";
          check.style.opacity = "1";
          check.style.color = "#fff";
        } else if (state === "partial") {
          btn.classList.add("active");
          dot.style.borderColor = "var(--color-sage)";
          dot.style.background = "transparent";
          check.style.opacity = "1";
          check.style.color = "var(--color-sage)";
        } else {
          btn.classList.remove("active");
          dot.style.borderColor = "var(--color-mist)";
          dot.style.background = "transparent";
          check.style.opacity = "0";
        }
      });
    }

    function updateOptionVisuals() {
      document.querySelectorAll("[data-option]").forEach((btn) => {
        const stageId = parseInt(btn.getAttribute("data-stage-id"));
        const opt = btn.getAttribute("data-option");
        const isSelected = selections[stageId].includes(opt);

        if (isSelected) {
          btn.classList.add("selected");
          btn.querySelector(".pf-option-dot").style.borderColor =
            "var(--color-sage)";
          btn.querySelector(".pf-option-dot svg").style.opacity = "1";
        } else {
          btn.classList.remove("selected");
          btn.querySelector(".pf-option-dot").style.borderColor =
            "var(--color-mist)";
          btn.querySelector(".pf-option-dot svg").style.opacity = "0";
        }
      });
    }

    function render() {
      document.querySelectorAll(".pf-stage").forEach((el) => {
        el.classList.remove("visible");
        el.classList.remove("active");
      });

      btnNext.style.display = "inline-flex";
      btnBack.style.visibility = "visible";
      btnBack.disabled = currentStage === 1;
      btnNextText.textContent =
        currentStage === totalStages ? "Finish" : "Continue";
      btnNext.disabled = !isStageComplete(currentStage);

      updateOptionVisuals();
      updateUmbrellaVisuals();

      const targetEl = document.querySelector(`[data-stage="${currentStage}"]`);

      if (targetEl) {
        targetEl.classList.add("active");
        void targetEl.offsetWidth;
        targetEl.classList.add("visible");
      }

      updateSidebar();
    }

    document.querySelectorAll("[data-umbrella]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const stageId = parseInt(btn.getAttribute("data-stage-id"));
        const header = btn.getAttribute("data-umbrella");
        toggleUmbrella(header, stageId);
        if (currentStage === stageId) {
          updateOptionVisuals();
          updateUmbrellaVisuals();
          btnNext.disabled = !isStageComplete(currentStage);
        }
      });
    });

    document.querySelectorAll("[data-option]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const stageId = parseInt(btn.getAttribute("data-stage-id"));
        const opt = btn.getAttribute("data-option");
        const idx = selections[stageId].indexOf(opt);

        if (idx > -1) selections[stageId].splice(idx, 1);
        else selections[stageId].push(opt);

        if (currentStage === stageId) {
          updateOptionVisuals();
          updateUmbrellaVisuals();
          btnNext.disabled = !isStageComplete(currentStage);
        }
      });
    });

    btnBack.addEventListener("click", () => {
      if (currentStage > 1) {
        currentStage--;
        render();
      }
    });

    btnNext.addEventListener("click", () => {
      if (currentStage < totalStages) {
        currentStage++;
        render();
      } else if (currentStage === totalStages) {
        console.log("Final Selections:", selections);

        // Close the modal
        closeModal();

        // Trigger the toast popup using the correct global function name
        // id="toast-popup" becomes window.showtoast_popup
        if (typeof window.showtoast_popup === "function") {
          window.showtoast_popup();
        } else {
          console.warn(
            "Toast popup function not found. Check that ToastPopup.astro is rendered on the page.",
          );
        }
      }
    });

    document.querySelectorAll("[data-step-nav]").forEach((el) => {
      el.addEventListener("click", () => {
        const step = parseInt(el.getAttribute("data-step"));

        let canNavigate = true;
        for (let i = 1; i < step; i++) {
          if (!isStageComplete(i)) canNavigate = false;
        }

        if (canNavigate) {
          currentStage = step;
          render();
        }
      });
    });

    closeBtn.addEventListener("click", closeModal);
    backdrop.addEventListener("click", closeModal);

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeModal();
    });

    document.body.style.overflow = "hidden";
    render();
  })();
</script>
