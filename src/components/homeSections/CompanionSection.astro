---

---

<section id="facilitators" class="py-24">
  <div class="max-w-[1140px] mx-auto px-7">
    <div 
      class="bg-[linear-gradient(165deg,#322341_0%,#241B2E_100%)] text-[#F6ECE3] rounded-[30px] px-8 py-11 md:px-14 md:py-16 grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-8 lg:gap-12 items-center"
    >
      {/* Left column */}
      <div>
        <span class="font-[Hanken_Grotesk] font-semibold text-[0.75rem] uppercase tracking-[0.16em] text-[#E0A35C] block mb-[22px]">
          For therapists, coaches & healers
        </span>

        <h2 class="font-[Fraunces] font-light text-[clamp(1.9rem,3.4vw,2.6rem)] tracking-[-0.025em] leading-[1.1] mt-[0.4em] mb-[0.5em]">
          Keep your practice <em class="italic text-[#C16F72]">entirely yours</em>.
        </h2>

        <p class="text-[rgba(246,236,227,0.8)] mb-6 max-w-[42ch] text-[17px] leading-[1.7]">
          circles.love is a clean, shareable page for the circle you already run — not a platform that owns your clients or your calendar.
        </p>

        <ul class="list-none p-0 mb-8 flex flex-col gap-3.5">
          <li class="flex gap-3 items-start text-[0.96rem] text-[rgba(246,236,227,0.92)]">
            <svg class="shrink-0 mt-[3px] text-[#E0A35C]" width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="m4 9 3 3 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            List a circle in minutes with one simple form — no website, no developer.
          </li>
          <li class="flex gap-3 items-start text-[0.96rem] text-[rgba(246,236,227,0.92)]">
            <svg class="shrink-0 mt-[3px] text-[#E0A35C]" width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="m4 9 3 3 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Share one link — in your email signature, on your site, with colleagues.
          </li>
          <li class="flex gap-3 items-start text-[0.96rem] text-[rgba(246,236,227,0.92)]">
            <svg class="shrink-0 mt-[3px] text-[#E0A35C]" width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="m4 9 3 3 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Seekers book and pay on your own secure portal. We never see it.
          </li>
        </ul>

        <a 
          href="#" 
          class="inline-flex items-center gap-[9px] font-[Hanken_Grotesk] font-semibold text-[0.95rem] px-6 py-3.5 rounded-full border border-transparent cursor-pointer no-underline transition-all duration-200 hover:-translate-y-px bg-[#C16F72] text-white hover:bg-[#A8504C] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#C16F72] focus-visible:ring-offset-2 focus-visible:ring-offset-[#241B2E]"
        >
          List your circle
        </a>
      </div>

      {/* Right column */}
      <div class="bg-[rgba(246,236,227,0.06)] border border-[rgba(246,236,227,0.14)] rounded-[20px] p-6">
        <div class="text-[0.72rem] uppercase tracking-[0.12em] text-[rgba(246,236,227,0.55)] font-semibold mb-3.5">
          What we take
        </div>
        <div class="font-[Fraunces] font-light text-5xl leading-none text-[#F6ECE3]">
          0%<span class="text-base text-[rgba(246,236,227,0.6)] ml-1">commission</span>
        </div>
        <div class="my-4 px-4 py-3.5 bg-[rgba(110,139,122,0.18)] rounded-xl text-[0.86rem] text-[#CFE0D4]">
          A full circle of 8 at <b class="text-white font-bold">$50</b> is <b class="text-white font-bold">$400</b> an evening — and every dollar stays with you.
        </div>
        <div class="text-[0.72rem] uppercase tracking-[0.12em] text-[rgba(246,236,227,0.55)] font-semibold mb-3.5">
          What it costs you
        </div>
        <div class="font-[Fraunces] font-light text-[2rem] leading-none text-[#F6ECE3]">
          Free<span class="text-base text-[rgba(246,236,227,0.6)] ml-1">to list in v1</span>
        </div>
      </div>

    </div>
  </div>
</section>