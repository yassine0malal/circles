---
// No props needed — content is static
---

<section id="facilitators" class="py-24">
  <div class="max-w-[1140px] mx-auto px-7">
    
    {/* Header */}
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="font-[Hanken_Grotesk] font-semibold text-[0.75rem] uppercase tracking-[0.16em] text-sage-deep">
        For those who hold space
      </span>
      <h2 class="font-[Fraunces] font-light text-4xl md:text-5xl tracking-tight text-ink mt-5 mb-4 leading-tight">
        Two ways to <em class="italic text-rose">share your gift</em>.
      </h2>
      <p class="text-ink-soft text-lg leading-relaxed">
        Whether you're a licensed clinician or a trained facilitator, circles.love gives you a clean page to list the circle you already run — with nothing in the middle.
      </p>
    </div>

    {/* Two Cards */}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      {/* Therapy Facilitator Card */}
      <div 
        class="group relative rounded-[22px] p-10 overflow-hidden border border-line bg-gradient-to-br from-[#EFF1EC] to-[#E7ECE5] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_18px_44px_rgba(42,33,53,0.08)]"
      >
        <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-5 h-5 text-sage-deep" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </div>

        <svg class="w-12 h-12 mb-5 text-sage-deep" viewBox="0 0 46 46" fill="none">
          <circle cx="19" cy="23" r="12" stroke="currentColor" stroke-width="2"/>
          <circle cx="27" cy="23" r="12" stroke="currentColor" stroke-width="2"/>
        </svg>

        <h3 class="font-[Fraunces] text-2xl font-normal tracking-tight text-ink mb-2">
          List a therapy circle
        </h3>
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-sage-deep mb-4">
          Symptom-Relief Focus
        </p>
        <p class="text-ink-soft text-base leading-relaxed mb-6">
          For licensed clinicians running clinical or psychoeducational groups. Your license is verified and displayed on every listing.
        </p>

        <ul class="space-y-3 mb-8">
          <li class="flex gap-3 items-start text-sm text-ink-soft">
            <svg class="shrink-0 mt-0.5 text-sage-deep" width="16" height="16" viewBox="0 0 18 18" fill="none">
              <path d="m4 9 3 3 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            License verification shown upfront
          </li>
          <li class="flex gap-3 items-start text-sm text-ink-soft">
            <svg class="shrink-0 mt-0.5 text-sage-deep" width="16" height="16" viewBox="0 0 18 18" fill="none">
              <path d="m4 9 3 3 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Set your own fee — we take 0%
          </li>
          <li class="flex gap-3 items-start text-sm text-ink-soft">
            <svg class="shrink-0 mt-0.5 text-sage-deep" width="16" height="16" viewBox="0 0 18 18" fill="none">
              <path d="m4 9 3 3 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            One link to share anywhere
          </li>
        </ul>

        <div class="bg-white/60 rounded-xl p-5 border border-line/50">
          <div class="text-[0.72rem] uppercase tracking-[0.12em] text-ink-soft font-semibold mb-2">
            What you keep
          </div>
          <div class="font-[Fraunces] font-light text-3xl text-ink">
            100%<span class="text-sm text-ink-soft ml-1">of your fee</span>
          </div>
          <div class="mt-2 text-xs text-ink-soft">
            A full circle of 8 at <b class="text-ink">$50</b> = <b class="text-ink">$400</b> — all yours.
          </div>
        </div>

        <a 
          href="#" 
          class="mt-6 inline-flex items-center gap-2 font-semibold text-sm px-6 py-3 rounded-full bg-ink text-cream hover:bg-sage transition-all duration-200 hover:-translate-y-px"
        >
          List your therapy circle
        </a>
      </div>

      {/* Healing Facilitator Card */}
      <div 
        class="group relative rounded-[22px] p-10 overflow-hidden border border-line bg-gradient-to-br from-[#FBF0E3] to-[#F7E9D8] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_18px_44px_rgba(42,33,53,0.08)]"
      >
        <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-5 h-5 text-amber" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </div>

        <svg class="w-12 h-12 mb-5 text-amber" viewBox="0 0 46 46" fill="none">
          <circle cx="23" cy="23" r="8" stroke="currentColor" stroke-width="2"/>
          <circle cx="23" cy="23" r="16" stroke="currentColor" stroke-width="2" opacity="0.5"/>
        </svg>

        <h3 class="font-[Fraunces] text-2xl font-normal tracking-tight text-ink mb-2">
          List a healing circle
        </h3>
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-amber mb-4">
          Values-Driven Exploration
        </p>
        <p class="text-ink-soft text-base leading-relaxed mb-6">
          For coaches, healers, and facilitators leading support circles. Your credentials and approach are stated up front.
        </p>

        <ul class="space-y-3 mb-8">
          <li class="flex gap-3 items-start text-sm text-ink-soft">
            <svg class="shrink-0 mt-0.5 text-amber" width="16" height="16" viewBox="0 0 18 18" fill="none">
              <path d="m4 9 3 3 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Credentials displayed transparently
          </li>
          <li class="flex gap-3 items-start text-sm text-ink-soft">
            <svg class="shrink-0 mt-0.5 text-amber" width="16" height="16" viewBox="0 0 18 18" fill="none">
              <path d="m4 9 3 3 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Set your own fee — we take 0%
          </li>
          <li class="flex gap-3 items-start text-sm text-ink-soft">
            <svg class="shrink-0 mt-0.5 text-amber" width="16" height="16" viewBox="0 0 18 18" fill="none">
              <path d="m4 9 3 3 7-7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            One link to share anywhere
          </li>
        </ul>

        <div class="bg-white/60 rounded-xl p-5 border border-line/50">
          <div class="text-[0.72rem] uppercase tracking-[0.12em] text-ink-soft font-semibold mb-2">
            What it costs
          </div>
          <div class="font-[Fraunces] font-light text-3xl text-ink">
            Free<span class="text-sm text-ink-soft ml-1">to list in v1</span>
          </div>
          <div class="mt-2 text-xs text-ink-soft">
            No monthly fee. No commission. No catch.
          </div>
        </div>

        <a 
          href="#" 
          class="mt-6 inline-flex items-center gap-2 font-semibold text-sm px-6 py-3 rounded-full bg-ink text-cream hover:bg-sage transition-all duration-200 hover:-translate-y-px"
        >
          List your healing circle
        </a>
      </div>

    </div>
  </div>
</section>