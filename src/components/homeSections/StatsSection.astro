<section class="py-24 px-8 bg-raised overflow-hidden">
  <div class="max-w-6xl mx-auto">
    
    {/* Heading */}
    <div class="text-center mb-20 scroll-animate opacity-0 translate-y-10 transition-all duration-700 ease-out">
      <p class="text-xs font-light tracking-[0.3em] uppercase text-ink-soft/70 mb-4">Introduction</p>
      <h2 class="text-4xl md:text-5xl text-ink leading-tight font-display">
        Welcome to a space<br />dedicated to your <span class="italic text-rose font-display">well-being</span>
      </h2>
    </div>

    {/* Stats Grid */}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 md:gap-8">
      {[
        { value: 80, suffix: '%', label: 'Emotional well-being' },
        { value: 10, suffix: '+', label: 'Thoughtfully designed circles' },
        { value: 300, suffix: '+', label: 'Shared moments of reflection' },
        { value: 50, suffix: '%', label: 'Return to continue their journey' },
      ].map((stat, i) => (
        <div 
          class="text-center scroll-animate opacity-0 translate-y-10 transition-all duration-700 ease-out"
          style={`transition-delay: ${i * 150}ms;`}
          data-delay={i * 150} 
        >
          {/* Added data attributes and a generic "0" starting state */}
          <p 
            class="font-display text-5xl md:text-6xl font-serif text-rose mb-3 stat-counter"
            data-target={stat.value}
            data-suffix={stat.suffix}
          >
            0{stat.suffix}
          </p>
          <p class="text-sm font-light text-ink-soft/70 leading-relaxed max-w-[140px] mx-auto">{stat.label}</p>
        </div>
      ))}
    </div>
    
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // Smooth counting animation function
    const animateCounter = (el) => {
      const target = parseInt(el.getAttribute('data-target') || '0', 10);
      const suffix = el.getAttribute('data-suffix') || '';
      const duration = 2000; // Total animation time in milliseconds
      let startTimestamp = null;

      const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        
        // Easing curve (ease-out-quart) so it slows down beautifully at the end
        const easeProgress = 1 - Math.pow(1 - progress, 4);
        const currentCount = Math.floor(easeProgress * target);
        
        el.textContent = currentCount + suffix;

        if (progress < 1) {
          window.requestAnimationFrame(step);
        } else {
          // Ensure it ends on the exact target number
          el.textContent = target + suffix;
        }
      };

      window.requestAnimationFrame(step);
    };

    // Intersection Observer to trigger animations on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Slide and fade up the container
          entry.target.classList.remove('opacity-0', 'translate-y-10');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          
          // Trigger the counter logic if the element has a counter inside it
          const counterEl = entry.target.querySelector('.stat-counter');
          if (counterEl) {
            // Read the clean number directly from the new data-delay attribute
            const delay = parseInt(entry.target.getAttribute('data-delay') || '0', 10);
            
            setTimeout(() => {
              animateCounter(counterEl);
            }, delay);
          }
          
          // Unobserve so it only happens once
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1, 
      rootMargin: "0px 0px -50px 0px" 
    });

    const animatedElements = document.querySelectorAll('.scroll-animate');
    animatedElements.forEach((el) => observer.observe(el));
  });
</script>