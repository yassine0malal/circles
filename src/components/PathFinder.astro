---
export interface Props {
  triggerLabel?: string;
  openOnLoad?: boolean;
}

const { triggerLabel = "Find Your Path", openOnLoad = false } = Astro.props;

const stages = [
  {
    id: 1,
    title: "What do I need?",
    subtitle: "Primary Need",
    description: "Choose the pathway that resonates most with where you are right now.",
    sections: [
      {
        header: "Deep Relational & Personal Growth",
        options: ["Heal", "Belong", "Grow", "Create"],
      },
      {
        header: "Tools, Skills & Support for Daily Life",
        options: ["Learn", "Support", "Restore"],
      },
    ],
  },
  {
    id: 2,
    title: "What kind of experience am I looking for?",
    subtitle: "Therapeutic Approach",
    description: "Select the engagement style and group format that feels right for you.",
    options: [
      "Process Group",
      "Psychoeducational Group",
      "Support Group",
      "Consultation Group",
      "Workshop Series",
      "Retreat",
      "Open Circle",
      "Closed Circle",
      "Drop-In",
    ],
  },
  {
    id: 3,
    title: "Who feels like the right guide?",
    subtitle: "Companion Profile",
    description: "What qualities do you want in your facilitator or companion?",
    options: [
      "Warm & Empathetic",
      "Direct & Honest",
      "Structured & Goal-Oriented",
      "Creative & Intuitive",
      "Spiritually-Grounded",
      "Trauma-Informed",
      "Playful & Light",
      "Wise & Experienced",
    ],
  },
];
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Hanken+Grotesk:wght@300..900&display=swap');

  :root {
    --color-ink: #2A2135;
    --color-ink-2: #241B2E;
    --color-ink-soft: #574B63;
    --color-canvas: #F8F2EE;
    --color-raised: #FFFDFB;
    --color-rose: #C16F72;
    --color-rose-ink: #A8504C;
    --color-amber: #E0A35C;
    --color-sage: #6E8B7A;
    --color-sage-deep: #4F6B5B;
    --color-mist: #EBE0D8;
    --color-cream: #F6ECE3;
    --color-line: rgba(42, 33, 53, 0.10);
    --font-display: "Fraunces", Georgia, serif;
    --font-body: "Hanken Grotesk", system-ui, sans-serif;
  }

  .pf-font-display { font-family: var(--font-display); }
  .pf-font-body { font-family: var(--font-body); }

  /* Custom scrollbar for the modal content */
  .pf-scroll::-webkit-scrollbar { width: 6px; }
  .pf-scroll::-webkit-scrollbar-track { background: transparent; }
  .pf-scroll::-webkit-scrollbar-thumb { background-color: var(--color-mist); border-radius: 20px; }

  /* Animations */
  .pf-fade-in { animation: pfFadeIn 0.3s ease-out forwards; }
  .pf-scale-in { animation: pfScaleIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  @keyframes pfFadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes pfScaleIn { from { opacity: 0; transform: scale(0.96); } to { opacity: 1; transform: scale(1); } }

  .pf-option-card {
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .pf-option-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(42, 33, 53, 0.06);
  }
  .pf-option-card.selected {
    border-color: var(--color-sage);
    background-color: rgba(110, 139, 122, 0.06);
    box-shadow: 0 0 0 1px var(--color-sage);
  }

  .pf-step-line {
    position: absolute;
    left: 15px;
    top: 32px;
    bottom: -8px;
    width: 2px;
    background: repeating-linear-gradient(
      to bottom,
      var(--color-line) 0,
      var(--color-line) 4px,
      transparent 4px,
      transparent 8px
    );
  }
  .pf-step-item:last-child .pf-step-line { display: none; }
</style>

<!-- Trigger Button -->
<button
  type="button"
  id="pf-trigger"
  class="pf-font-body inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold text-white transition-all hover:opacity-90 active:scale-95"
  style="background-color: var(--color-sage);"
>
  <span>{triggerLabel}</span>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
</button>

<!-- Modal -->
<div
  id="pf-modal"
  class="fixed inset-0 z-50 hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="pf-modal-title"
>
  <!-- Backdrop -->
  <div
    id="pf-backdrop"
    class="absolute inset-0 transition-opacity"
    style="background-color: rgba(42, 33, 53, 0.45); backdrop-filter: blur(6px);"
  ></div>

  <!-- Modal Card -->
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div
      id="pf-card"
      class="pf-scale-in w-full max-w-4xl overflow-hidden rounded-2xl shadow-2xl flex flex-col md:flex-row"
      style="background-color: var(--color-raised); min-height: 580px; max-height: 90vh;"
    >
      <!-- Left Sidebar -->
      <aside
        class="w-full md:w-72 flex flex-col border-b md:border-b-0 md:border-r p-6 md:p-8"
        style="background-color: var(--color-canvas); border-color: var(--color-line);"
      >
        <div class="mb-8">
          <h2 class="pf-font-display text-2xl font-semibold" style="color: var(--color-ink);">Find Your Path</h2>
          <p class="text-sm mt-1" style="color: var(--color-ink-soft);">3 questions to guide you home</p>
        </div>

        <nav class="flex-1 relative">
          {stages.map((stage, idx) => (
            <div
              class="pf-step-item relative pl-10 pb-8 cursor-pointer group"
              data-step={stage.id}
              data-step-nav
            >
              <!-- Connector Line -->
              <div class="pf-step-line"></div>

              <!-- Indicator -->
              <div
                class="pf-step-indicator absolute left-0 top-0 w-8 h-8 rounded-full flex items-center justify-center transition-all duration-300"
                data-indicator={stage.id}
                style="border: 2px solid var(--color-mist); color: var(--color-ink-soft); background: var(--color-raised);"
              >
                <span class="pf-step-number text-sm font-semibold" data-number={stage.id}>{stage.id}</span>
                <svg class="pf-step-check hidden w-4 h-4 text-white" data-check={stage.id} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>

              <!-- Text -->
              <div
                class="pf-step-content -mt-1 transition-all duration-300 rounded-lg p-2 -ml-2"
                data-content={stage.id}
              >
                <h3 class="text-sm font-semibold leading-tight" style="color: var(--color-ink);">{stage.title}</h3>
                <p class="text-xs mt-0.5" style="color: var(--color-ink-soft);">{stage.subtitle}</p>
              </div>
            </div>
          ))}
        </nav>

        <!-- Progress -->
        <div class="mt-auto pt-6 hidden md:block">
          <div class="flex items-center justify-between text-xs mb-2" style="color: var(--color-ink-soft);">
            <span>Progress</span>
            <span id="pf-progress-text">1 / 3</span>
          </div>
          <div class="h-1.5 w-full rounded-full overflow-hidden" style="background-color: var(--color-mist);">
            <div
              id="pf-progress-bar"
              class="h-full rounded-full transition-all duration-500 ease-out"
              style="background-color: var(--color-sage); width: 33%;"
            ></div>
          </div>
        </div>
      </aside>

      <!-- Right Content -->
      <main class="flex-1 flex flex-col overflow-hidden" style="background-color: var(--color-raised);">
        <!-- Scrollable Content -->
        <div class="flex-1 overflow-y-auto pf-scroll p-6 md:p-10">
          {stages.map((stage) => (
            <div
              class="pf-stage hidden"
              data-stage={stage.id}
            >
              <div class="mb-2">
                <span class="inline-block text-xs font-bold tracking-wider uppercase rounded-full px-3 py-1 mb-3" style="background-color: var(--color-cream); color: var(--color-rose-ink);">
                  Step {stage.id}
                </span>
              </div>
              <h2
                id="pf-modal-title"
                class="pf-font-display text-2xl md:text-3xl font-semibold mb-2"
                style="color: var(--color-ink);"
              >
                {stage.title}
              </h2>
              <p class="text-base md:text-lg mb-8 leading-relaxed" style="color: var(--color-ink-soft);">
                {stage.description}
              </p>

              <!-- Options -->
              <div class="space-y-6">
                {"sections" in stage ? (
                  stage.sections.map((section) => (
                    <div>
                      <h4 class="text-xs font-bold tracking-wider uppercase mb-3" style="color: var(--color-ink-soft);">
                        {section.header}
                      </h4>
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        {section.options.map((opt) => (
                          <button
                            type="button"
                            class="pf-option-card pf-font-body text-left rounded-xl border p-4 md:p-5 relative group"
                            style="border-color: var(--color-line); background-color: var(--color-raised); color: var(--color-ink);"
                            data-option={opt}
                            data-stage-id={stage.id}
                          >
                            <div class="flex items-center justify-between">
                              <span class="font-medium text-sm md:text-base">{opt}</span>
                              <div
                                class="pf-option-dot w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all"
                                style="border-color: var(--color-mist);"
                              >
                                <div class="w-2.5 h-2.5 rounded-full opacity-0 transition-all" style="background-color: var(--color-sage);"></div>
                              </div>
                            </div>
                          </button>
                        ))}
                      </div>
                    </div>
                  ))
                ) : (
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    {stage.options.map((opt) => (
                      <button
                        type="button"
                        class="pf-option-card pf-font-body text-left rounded-xl border p-4 md:p-5 relative group"
                        style="border-color: var(--color-line); background-color: var(--color-raised); color: var(--color-ink);"
                        data-option={opt}
                        data-stage-id={stage.id}
                      >
                        <div class="flex items-center justify-between">
                          <span class="font-medium text-sm md:text-base">{opt}</span>
                          <div
                            class="pf-option-dot w-5 h-5 rounded-full border-2 flex items-center justify-center transition-all"
                            style="border-color: var(--color-mist);"
                          >
                            <div class="w-2.5 h-2.5 rounded-full opacity-0 transition-all" style="background-color: var(--color-sage);"></div>
                          </div>
                        </div>
                      </button>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}

          <!-- Summary / Completion -->
          <div class="pf-stage hidden" data-stage="summary">
            <div class="text-center py-10">
              <div
                class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6"
                style="background-color: var(--color-sage);"
              >
                <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <h2 class="pf-font-display text-2xl md:text-3xl font-semibold mb-3" style="color: var(--color-ink);">Your path is illuminated</h2>
              <p class="text-base mb-8 max-w-md mx-auto" style="color: var(--color-ink-soft);">
                Thank you for sharing. We've gathered your preferences and will use them to guide you toward the right experience.
              </p>
              <div id="pf-summary-details" class="text-left max-w-md mx-auto space-y-3 mb-8"></div>
              <button
                type="button"
                id="pf-restart"
                class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold text-white transition-all hover:opacity-90"
                style="background-color: var(--color-sage);"
              >
                <span>Start Over</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div
          class="flex items-center justify-between p-6 md:px-10 md:py-6 border-t"
          style="border-color: var(--color-line); background-color: var(--color-raised);"
        >
          <button
            type="button"
            id="pf-btn-back"
            class="pf-font-body inline-flex items-center gap-2 rounded-lg px-4 py-2.5 text-sm font-medium transition-all disabled:opacity-30 disabled:cursor-not-allowed hover:bg-black/5"
            style="color: var(--color-ink);"
            disabled
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Back
          </button>

          <button
            type="button"
            id="pf-btn-next"
            class="pf-font-body inline-flex items-center gap-2 rounded-xl px-6 py-2.5 text-sm font-semibold text-white transition-all hover:opacity-90 active:scale-95 disabled:opacity-40 disabled:cursor-not-allowed"
            style="background-color: var(--color-ink);"
            disabled
          >
            <span id="pf-btn-next-text">Continue</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </main>
    </div>
  </div>
</div>

<script>
  (function() {
    const modal = document.getElementById('pf-modal');
    const backdrop = document.getElementById('pf-backdrop');
    const trigger = document.getElementById('pf-trigger');
    const card = document.getElementById('pf-card');
    const btnBack = document.getElementById('pf-btn-back');
    const btnNext = document.getElementById('pf-btn-next');
    const btnNextText = document.getElementById('pf-btn-next-text');
    const progressBar = document.getElementById('pf-progress-bar');
    const progressText = document.getElementById('pf-progress-text');
    const summaryDetails = document.getElementById('pf-summary-details');
    const restartBtn = document.getElementById('pf-restart');

    let currentStage = 1;
    const totalStages = 3;
    const selections = { 1: null, 2: null, 3: [] };

    const stageData = [
      { id: 1, title: "What do I need?", subtitle: "Primary Need" },
      { id: 2, title: "What kind of experience am I looking for?", subtitle: "Therapeutic Approach" },
      { id: 3, title: "Who feels like the right guide?", subtitle: "Companion Profile" },
    ];

    function openModal() {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      render();
    }

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    function updateSidebar() {
      for (let i = 1; i <= totalStages; i++) {
        const indicator = document.querySelector(`[data-indicator="${i}"]`);
        const number = document.querySelector(`[data-number="${i}"]`);
        const check = document.querySelector(`[data-check="${i}"]`);
        const content = document.querySelector(`[data-content="${i}"]`);
        const item = document.querySelector(`[data-step="${i}"]`);

        // Reset
        indicator.style.cssText = '';
        indicator.style.border = '2px solid var(--color-mist)';
        indicator.style.color = 'var(--color-ink-soft)';
        indicator.style.background = 'var(--color-raised)';
        number.classList.remove('hidden');
        check.classList.add('hidden');
        content.style.background = 'transparent';
        content.style.marginLeft = '-0.5rem';
        content.style.padding = '0.5rem';
        content.style.borderRadius = '0.5rem';

        if (i < currentStage) {
          // Completed
          indicator.style.background = 'var(--color-sage)';
          indicator.style.borderColor = 'var(--color-sage)';
          indicator.style.color = '#fff';
          number.classList.add('hidden');
          check.classList.remove('hidden');
          content.style.opacity = '1';
        } else if (i === currentStage) {
          // Current
          indicator.style.background = 'var(--color-ink)';
          indicator.style.borderColor = 'var(--color-ink)';
          indicator.style.color = '#fff';
          content.style.background = 'var(--color-cream)';
        } else {
          // Pending
          content.style.opacity = '0.6';
        }
      }

      // Progress bar
      const pct = currentStage > totalStages ? 100 : ((currentStage - 1) / totalStages) * 100;
      progressBar.style.width = pct + '%';
      progressText.textContent = `${Math.min(currentStage, totalStages)} / ${totalStages}`;
    }

    function render() {
      // Hide all stages
      document.querySelectorAll('.pf-stage').forEach(el => el.classList.add('hidden'));

      if (currentStage > totalStages) {
        // Show summary
        document.querySelector('[data-stage="summary"]').classList.remove('hidden');
        btnNext.classList.add('hidden');
        btnBack.disabled = true;
        btnBack.style.visibility = 'hidden';

        // Build summary
        const s1 = selections[1] || '—';
        const s2 = selections[2] || '—';
        const s3 = selections[3].length ? selections[3].join(', ') : '—';

        summaryDetails.innerHTML = `
          <div class="rounded-xl p-4 border" style="border-color: var(--color-line); background: var(--color-canvas);">
            <div class="text-xs font-bold uppercase tracking-wider mb-1" style="color: var(--color-ink-soft);">Primary Need</div>
            <div class="font-medium" style="color: var(--color-ink);">${s1}</div>
          </div>
          <div class="rounded-xl p-4 border" style="border-color: var(--color-line); background: var(--color-canvas);">
            <div class="text-xs font-bold uppercase tracking-wider mb-1" style="color: var(--color-ink-soft);">Experience</div>
            <div class="font-medium" style="color: var(--color-ink);">${s2}</div>
          </div>
          <div class="rounded-xl p-4 border" style="border-color: var(--color-line); background: var(--color-canvas);">
            <div class="text-xs font-bold uppercase tracking-wider mb-1" style="color: var(--color-ink-soft);">Companion</div>
            <div class="font-medium" style="color: var(--color-ink);">${s3}</div>
          </div>
        `;
      } else {
        // Show active stage
        document.querySelector(`[data-stage="${currentStage}"]`).classList.remove('hidden');
        btnNext.classList.remove('hidden');
        btnBack.style.visibility = 'visible';
        btnBack.disabled = currentStage === 1;
        btnNextText.textContent = currentStage === totalStages ? 'Finish' : 'Continue';

        // Enable next only if selection exists
        const hasSelection = currentStage === 3 ? selections[3].length > 0 : selections[currentStage] !== null;
        btnNext.disabled = !hasSelection;

        // Update option cards visual state
        document.querySelectorAll(`[data-stage-id="${currentStage}"]`).forEach(btn => {
          const opt = btn.getAttribute('data-option');
          const isSelected = currentStage === 3
            ? selections[3].includes(opt)
            : selections[currentStage] === opt;

          if (isSelected) {
            btn.classList.add('selected');
            btn.querySelector('.pf-option-dot').style.borderColor = 'var(--color-sage)';
            btn.querySelector('.pf-option-dot div').style.opacity = '1';
          } else {
            btn.classList.remove('selected');
            btn.querySelector('.pf-option-dot').style.borderColor = 'var(--color-mist)';
            btn.querySelector('.pf-option-dot div').style.opacity = '0';
          }
        });
      }

      updateSidebar();
    }

    // Event: option click
    document.querySelectorAll('[data-option]').forEach(btn => {
      btn.addEventListener('click', () => {
        const stageId = parseInt(btn.getAttribute('data-stage-id'));
        const opt = btn.getAttribute('data-option');

        if (stageId === 3) {
          // Multi-select for stage 3
          const idx = selections[3].indexOf(opt);
          if (idx > -1) selections[3].splice(idx, 1);
          else selections[3].push(opt);
        } else {
          // Single select
          selections[stageId] = selections[stageId] === opt ? null : opt;
        }

        if (currentStage === stageId) render();
      });
    });

    // Event: navigation
    btnBack.addEventListener('click', () => {
      if (currentStage > 1) {
        currentStage--;
        render();
      }
    });

    btnNext.addEventListener('click', () => {
      if (currentStage <= totalStages) {
        currentStage++;
        render();
      }
    });

    // Event: sidebar click to jump back
    document.querySelectorAll('[data-step-nav]').forEach(el => {
      el.addEventListener('click', () => {
        const step = parseInt(el.getAttribute('data-step'));
        if (step < currentStage) {
          currentStage = step;
          render();
        }
      });
    });

    // Event: open/close
    trigger.addEventListener('click', openModal);
    backdrop.addEventListener('click', closeModal);
    restartBtn.addEventListener('click', () => {
      currentStage = 1;
      selections[1] = null;
      selections[2] = null;
      selections[3] = [];
      render();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });

    // Open on load if requested
    if ({openOnLoad}) {
      openModal();
    }
  })();
</script>