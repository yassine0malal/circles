---
import Footer from '../components/Footer.astro';
import Header from '../components/headers/Header.astro';
import "../styles/global.css";

interface Props {
  title: string;
  showHeader?:boolean;
}

const { title,showHeader=true } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  
  <!-- Google Fonts: Fraunces + Hanken Grotesk -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  

</head>
<body class="bg-canvas text-ink antialiased selection:bg-rose selection:text-white">
 {showHeader && <Header />}
  <slot />
  <Footer/>
</body>
</html>